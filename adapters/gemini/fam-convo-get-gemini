#!/usr/bin/env bash
# Summarization always uses Claude regardless of active brain.
# When history > 20 turns, oldest 10 are summarized by Claude before formatting.
#
# NOTE: Multi-turn conversation via subprocess CLIs is best-effort text formatting only.
# History is prepended as plain text — not a structured API. Gemini CLI does not accept
# a structured conversation format through stdin. Real multi-turn deferred to Session 9.
set -euo pipefail

TAG="${1:-latest-convo}"
# Second arg is optional history file (must be a readable .json file)
HISTORY_FILE=""
if [ $# -ge 2 ] && [ -f "${2:-}" ]; then
  HISTORY_FILE="$2"
  shift 2 || true
else
  shift 1 || true
fi

ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/famtastic/agent-hub/sources/gemini"
OUT="$ROOT/$TAG.jsonl"
mkdir -p "$ROOT"

# Prompt: remaining args or stdin
if [ $# -gt 0 ]; then PROMPT="$*"; else PROMPT="$(cat)"; fi
[ -n "${PROMPT:-}" ] || PROMPT="say ok"

# Prepend conversation history (last 20 turns) if provided
if [ -n "$HISTORY_FILE" ]; then
  CONTEXT="$(jq -r '.messages[] | "\(.role): \(.content)"' "$HISTORY_FILE" 2>/dev/null | tail -20 || true)"
  if [ -n "$CONTEXT" ]; then
    PROMPT="$(printf '%s\n\nuser: %s' "$CONTEXT" "$PROMPT")"
  fi
fi

# Set ORIG_PROMPT so log-jsonl can record the user turn correctly
export ORIG_PROMPT="$PROMPT"

# Resolve hub root (prefer env, fall back to relative path from this script)
HUB_ROOT="${HUB_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"

# Call native CLI
RESP="$(printf "%s" "$PROMPT" | "$HUB_ROOT/scripts/gemini-cli")"

# Output response to stdout (read by spawnBrainAdapter in server.js)
printf '%s\n' "$RESP"

# Append JSONL record
TS="$(date -u +%FT%TZ)"
printf '%s\n' "$(jq -c --null-input \
  --arg t "$TS" --arg p "$PROMPT" --arg r "$RESP" --arg a "gemini" \
  '{agent:$a, at:$t, tags:[], messages:[{"role":"user","content":$p},{"role":"assistant","content":$r}]}')" >> "$OUT"

echo "[gemini:get] $TAG → $OUT (+1)" >&2
