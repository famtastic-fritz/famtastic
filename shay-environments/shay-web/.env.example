# Shay Web — upstream hermes-webui v0.51 configured to talk to Shay
# Copy this file to .env and customize. Do NOT commit .env if it contains secrets.
HERMES_WEBUI_CHAT_BACKEND=gateway
HERMES_WEBUI_GATEWAY_BASE_URL=http://127.0.0.1:8642
# When the gateway requires a bearer (API_SERVER_KEY), this MUST match it.
# For local dev with anonymous loopback, leave empty.
HERMES_WEBUI_GATEWAY_API_KEY=
# Point hermes-state and the in-process kanban / skills / memory at Shay's home.
HERMES_HOME=/Users/famtasticfritz/.shay
HERMES_WEBUI_PORT=8787
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_STATE_DIR=/Users/famtasticfritz/.shay/webui
HERMES_WEBUI_PRESERVE_ENV=1
