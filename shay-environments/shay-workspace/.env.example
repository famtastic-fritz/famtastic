# Shay Workspace — upstream hermes-workspace v2.3 wired to talk to Shay.
# Copy to .env and fill in HERMES_DASHBOARD_TOKEN with any opaque string;
# the same value must be set as SHAY_DASHBOARD_TOKEN in the dashboard's env.

HERMES_API_URL=http://127.0.0.1:8642
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Workspace sends this as Authorization: Bearer <value> to the dashboard.
# Must match SHAY_DASHBOARD_TOKEN in the dashboard process environment.
HERMES_DASHBOARD_TOKEN=

# Filesystem root for memory/knowledge/profiles. Point at Shay's home.
HERMES_HOME=/Users/famtasticfritz/.shay

# Runtime port. `npm run dev` (vite) ignores this and uses 3000.
# `npm start` / Electron-bundled server honors APP_PORT and defaults to 3847.
APP_PORT=3847

# Skip the upstream Hermes installer offer.
HERMES_SKIP_INSTALL_OFFER=1
