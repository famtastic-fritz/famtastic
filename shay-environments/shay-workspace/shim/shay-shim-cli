#!/usr/bin/env python3
"""
shay-shim-cli — argv-compatible `hermes` CLI shim for Shay Workspace.

Upstream `hermes-workspace` v2.3.0 shells out to a `hermes` binary for four
feature surfaces (swarm tmux, swarm dispatch, mcp test, cron). It selects the
binary via the HERMES_CLI_BIN env var. This shim implements that argv contract
in Python so the Workspace UI's dormant tabs (Swarm, Conductor, MCP, Cron) can
light up against the Shay brain instead of the upstream Hermes runtime.

Routing model:
  - chat verbs route to shay_agent_os.components.swarm.brain_client.BrainChain
    via in-process import (no subprocess). The brain chain handles
    Claude→OpenRouter→Gemini→Ollama fallback automatically.
  - mcp/cron/tmux verbs return graceful "not-yet-implemented" stubs that
    match the upstream output shape so Workspace's parsers don't crash.

Wired verbs:
  chat --tui                                 implemented (TUI loop)
  chat -q -Q --yolo --source swarm-dispatch  implemented (oneshot prompt→answer)
  mcp test <name>                            stub (returns "Connection failed")
  --profile <p> cron list|create|edit|remove|pause|resume|run
                                             stub (returns benign output)

Constraints:
  - READ-ONLY on _refs/ (this binary lives outside the upstream clone)
  - Owned by shay-environments/shay-workspace/ only
  - Imports from shay-agent-os (added to sys.path at runtime)
"""

from __future__ import annotations

import argparse
import json
import os
import random
import sys
import time
from pathlib import Path
from typing import List, Optional

# Make shay-agent-os importable without requiring `pip install -e`.
_REPO_ROOT = Path(__file__).resolve().parents[3]
_AGENT_OS = _REPO_ROOT / "shay-agent-os"
if _AGENT_OS.is_dir() and str(_AGENT_OS) not in sys.path:
    sys.path.insert(0, str(_AGENT_OS))


def _lazy_brain():
    """Import BrainChain lazily so stub verbs never pay the import cost."""
    try:
        from components.swarm.brain_client import BrainChain  # type: ignore
        return BrainChain
    except Exception as exc:  # noqa: BLE001
        print(f"[shay-shim] brain import failed: {exc}", file=sys.stderr)
        return None


# ---------------------------------------------------------------------------
# chat verb
# ---------------------------------------------------------------------------

def cmd_chat(args: argparse.Namespace, extras: List[str]) -> int:
    """
    Two modes:
      * --tui                : interactive REPL (used by `hermes chat --tui`
                               inside the workspace tmux session)
      * -q -Q (quiet+oneshot): read prompt from stdin (or trailing arg) and
                               print the model's answer in a format compatible
                               with the workspace's checkpoint parser.
    """
    if args.tui:
        return _chat_tui()
    return _chat_oneshot(args, extras)


def _chat_tui() -> int:
    print("Shay Workspace — chat --tui (shim mode)")
    print(f"  HERMES_HOME = {os.environ.get('HERMES_HOME', '(unset)')}")
    print("  Routes via shay-agent-os BrainChain (Claude→OpenRouter→Gemini→Ollama).")
    print("  Type a prompt, blank line submits. Ctrl-D to exit.\n")
    BrainChain = _lazy_brain()
    chain = BrainChain() if BrainChain else None
    if chain is None:
        print("[shim] BrainChain unavailable — running in echo-only mode.")
    while True:
        try:
            buf: List[str] = []
            while True:
                line = input("» " if not buf else "  ")
                if line == "":
                    break
                buf.append(line)
            prompt = "\n".join(buf).strip()
            if not prompt:
                continue
            if chain is None:
                print(f"[echo] {prompt}")
                continue
            try:
                answer = chain.call_prompt(prompt)
            except Exception as exc:  # noqa: BLE001
                print(f"[brain error] {exc}")
                continue
            print(answer)
            print()
        except (EOFError, KeyboardInterrupt):
            print()
            return 0


def _chat_oneshot(args: argparse.Namespace, extras: List[str]) -> int:
    # Workspace builds the prompt via argv (with a wrapper) or stdin (raw bin).
    prompt = ""
    if extras:
        prompt = extras[-1]
    if not prompt and not sys.stdin.isatty():
        prompt = sys.stdin.read()
    prompt = (prompt or "").strip()
    if not prompt:
        print("[shay-shim] no prompt provided", file=sys.stderr)
        return 2

    BrainChain = _lazy_brain()
    if BrainChain is None:
        # Emit a synthetic checkpoint so the workspace parser sees something.
        print(_synthetic_checkpoint("BLOCKED",
                                    result="brain chain import failed",
                                    blocker="shay-agent-os not on sys.path"))
        return 1

    chain = BrainChain()
    try:
        answer = chain.call_prompt(prompt, timeout=240.0)
    except Exception as exc:  # noqa: BLE001
        print(_synthetic_checkpoint("BLOCKED",
                                    result=f"brain call failed: {exc}",
                                    blocker=str(exc)))
        return 1

    # Always wrap the answer in a checkpoint block so the workspace
    # `parseSwarmCheckpoint` regex picks up a STATE line.
    sys.stdout.write(answer)
    if "STATE:" not in answer:
        sys.stdout.write("\n\n")
        sys.stdout.write(_synthetic_checkpoint(
            "DONE",
            result=answer.strip().splitlines()[-1][:200] if answer.strip() else "ok",
        ))
    sys.stdout.write("\n")
    return 0


def _synthetic_checkpoint(state: str, *, result: str = "ok",
                          blocker: Optional[str] = None,
                          next_action: str = "none") -> str:
    return (
        f"STATE: {state}\n"
        f"FILES_CHANGED: none\n"
        f"COMMANDS_RUN: none\n"
        f"RESULT: {result}\n"
        f"BLOCKER: {blocker or 'none'}\n"
        f"NEXT_ACTION: {next_action}\n"
    )


# ---------------------------------------------------------------------------
# mcp verb — stub
# ---------------------------------------------------------------------------

def cmd_mcp(extras: List[str]) -> int:
    """`hermes mcp test <name>` — return a parseable "failed" result.

    The upstream parser (`parseHermesTestOutput`) treats anything matching
    `Connection failed (Xms): <err>` as a clean negative. That keeps the
    Workspace MCP screen functional without an MCP runtime behind it.
    """
    if not extras or extras[0] != "test" or len(extras) < 2:
        print("usage: hermes mcp test <name>", file=sys.stderr)
        return 2
    name = extras[1]
    print(f"Testing MCP server: {name}")
    print("✗ Connection failed (0ms): shay-shim has no MCP runtime wired yet")
    return 1


# ---------------------------------------------------------------------------
# cron verb — stub
# ---------------------------------------------------------------------------

def cmd_cron(profile: Optional[str], extras: List[str]) -> int:
    if not extras:
        print("usage: hermes --profile <p> cron <action> ...", file=sys.stderr)
        return 2
    action = extras[0]
    if action == "list":
        # Workspace also reads ~/.hermes/profiles/<p>/cron/jobs.json directly,
        # so empty stdout here is fine.
        print(json.dumps({"jobs": []}))
        return 0
    if action == "create":
        # Synthesize a job id so `parseCreatedJobId` finds something.
        job_id = "".join(random.choices("0123456789abcdef", k=16))
        print(f"Created job: {job_id}")
        return 0
    if action in {"edit", "remove", "pause", "resume", "run"}:
        target = extras[1] if len(extras) > 1 else "(none)"
        print(f"{action.capitalize()} ok: {target}")
        return 0
    print(f"[shay-shim] cron action '{action}' not implemented", file=sys.stderr)
    return 2


# ---------------------------------------------------------------------------
# argv dispatch
# ---------------------------------------------------------------------------

def _parse_global(argv: List[str]):
    """Split out `--profile <p>` global flag before the verb."""
    profile: Optional[str] = None
    rest: List[str] = []
    i = 0
    while i < len(argv):
        tok = argv[i]
        if tok == "--profile" and i + 1 < len(argv):
            profile = argv[i + 1]
            i += 2
            continue
        rest.append(tok)
        i += 1
    return profile, rest


def main(argv: Optional[List[str]] = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        print("shay-shim-cli — hermes argv shim. Verbs: chat, mcp, cron")
        return 0

    profile, argv = _parse_global(argv)
    verb, rest = argv[0], argv[1:]

    if verb == "chat":
        parser = argparse.ArgumentParser(prog="hermes chat", add_help=False)
        parser.add_argument("--tui", action="store_true")
        parser.add_argument("-q", action="store_true")
        parser.add_argument("-Q", action="store_true")
        parser.add_argument("--yolo", action="store_true")
        parser.add_argument("--ignore-rules", action="store_true")
        parser.add_argument("--source", default=None)
        ns, extras = parser.parse_known_args(rest)
        return cmd_chat(ns, extras)

    if verb == "mcp":
        return cmd_mcp(rest)

    if verb == "cron":
        return cmd_cron(profile, rest)

    if verb in {"--version", "-V"}:
        print("shay-shim-cli 0.1.0 (hermes argv shim)")
        return 0

    print(f"[shay-shim] unknown verb: {verb}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
