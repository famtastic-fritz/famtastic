{
  "schema_version": "0.1.0",
  "created_at": "2026-05-04",
  "status": "phase_1_catalog_only",
  "execution_order_changed": false,
  "source_functions": {
    "build": "site-studio/server.js parallelBuild()",
    "post_processing": "site-studio/server.js finishParallelBuild() and runPostProcessing()",
    "verification": "site-studio/server.js runBuildVerification()"
  },
  "stages": [
    {
      "stage_id": "intake",
      "boundary": "request enters Studio build path before parallelBuild",
      "inputs": ["userMessage", "requestType", "spec", "currentPage"],
      "outputs": ["run_id", "classification_trace", "ledger"],
      "proof_events": ["classification"]
    },
    {
      "stage_id": "parallel_build_start",
      "boundary": "parallelBuild() entry",
      "inputs": ["spec", "specPages", "userMessage", "prompt_contexts"],
      "outputs": ["start_time", "parallel_trace_run_id"],
      "proof_events": ["start"]
    },
    {
      "stage_id": "page_inventory",
      "boundary": "specPages normalized into output filenames",
      "inputs": ["specPages"],
      "outputs": ["pageFiles", "allPageLinks"],
      "proof_events": ["page_inventory"]
    },
    {
      "stage_id": "template_generation",
      "boundary": "shared template prompt built and executed",
      "inputs": ["templatePrompt", "sdk_or_subscription_route", "model"],
      "outputs": ["_template.html", "template_response", "template_error"],
      "proof_events": ["template_start", "template_written", "template_failed", "template_empty"]
    },
    {
      "stage_id": "template_artifacts",
      "boundary": "template parsed into reusable context",
      "inputs": ["_template.html"],
      "outputs": ["assets/styles.css", "_partials", "templateContext"],
      "proof_events": ["template_written", "template_incomplete"]
    },
    {
      "stage_id": "page_generation",
      "boundary": "page prompts fan out through SDK or subscription route",
      "inputs": ["pageFiles", "templateContext", "siteContext", "sharedRules"],
      "outputs": ["page_html_results", "page_failures"],
      "proof_events": ["pages_start", "page_written", "page_failed"]
    },
    {
      "stage_id": "post_processing",
      "boundary": "generated files are normalized after page writes",
      "inputs": ["writtenPages", "dist_dir", "spec"],
      "outputs": ["normalized_assets", "slots", "seo_files", "structural_index"],
      "proof_events": ["post_process", "slot_registration", "seo_validation"]
    },
    {
      "stage_id": "verification",
      "boundary": "build verification runs and result is persisted",
      "inputs": ["writtenPages", "dist_dir"],
      "outputs": ["verification_result", "fam_score", "issues"],
      "proof_events": ["run_build_verification"]
    },
    {
      "stage_id": "completion",
      "boundary": "Studio sends completion messages and optional repo creation",
      "inputs": ["verification_result", "writtenPages", "elapsed"],
      "outputs": ["assistant_summary", "preview_reload", "pages_updated", "site_repo"],
      "proof_events": ["assistant_complete", "repo_create"]
    }
  ],
  "next_step": "Use this catalog to drive Workbench inspect/trace surfaces only after trace events are present in real builds."
}
