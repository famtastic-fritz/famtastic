{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FAMtastic Site Spec",
  "description": "Specification for a site built by the FAMtastic site orchestrator",
  "type": "object",
  "required": ["site_name", "tag", "colors", "pages"],
  "properties": {
    "site_name": {
      "type": "string",
      "description": "Display name of the site"
    },
    "tag": {
      "type": "string",
      "pattern": "^site-[a-z0-9-]+$",
      "description": "Unique tag identifier (must start with site-)"
    },
    "business_type": {
      "type": "string",
      "description": "Type of business/purpose (e.g. event, restaurant, portfolio)"
    },
    "colors": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      },
      "required": ["primary"]
    },
    "pages": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of pages to generate (e.g. home, about, services, contact). Each becomes a separate HTML file."
    },
    "features": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Features to include (hero_banner, contact_form, countdown_timer, etc.)"
    },
    "tone": {
      "type": "string",
      "description": "Desired tone/voice for the copy"
    },
    "fonts": {
      "type": "object",
      "properties": {
        "heading": { "type": "string" },
        "body": { "type": "string" }
      }
    },
    "assets_needed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Visual assets to generate (logo, hero_banner, etc.)"
    },
    "state": {
      "type": "string",
      "enum": ["drafting", "incubating", "blueprint", "prototype", "validating", "deployed"],
      "description": "Current lifecycle state"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "deployed_url": {
      "type": "string",
      "description": "Live URL after deployment"
    },
    "deployed_at": {
      "type": "string",
      "description": "ISO timestamp of last deployment"
    },
    "domain": {
      "type": "string",
      "description": "Custom domain (registered via GoDaddy reseller)"
    },
    "design_brief": {
      "type": "object",
      "description": "Structured design brief created during planning mode",
      "properties": {
        "goal": { "type": "string" },
        "audience": { "type": "string" },
        "tone": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visual_direction": {
          "type": "object",
          "properties": {
            "layout": { "type": "string" },
            "typography": { "type": "string" },
            "color_usage": { "type": "string" },
            "motion": { "type": "string" },
            "density": { "type": "string" }
          }
        },
        "content_priorities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_have_sections": {
          "type": "array",
          "items": { "type": "string" }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approved": {
          "type": "boolean",
          "description": "Whether the user has approved this brief"
        }
      }
    },
    "design_decisions": {
      "type": "array",
      "description": "Log of durable design decisions made during the build",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["typography", "layout", "color", "content", "interaction", "structure"]
          },
          "decision": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["approved", "rejected", "superseded"]
          }
        },
        "required": ["timestamp", "category", "decision", "status"]
      }
    },
    "uploaded_assets": {
      "type": "array",
      "description": "Assets uploaded by the user with intent metadata",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["image", "text", "prompt", "logo", "screenshot"]
          },
          "role": {
            "type": "string",
            "enum": ["inspiration", "content", "brand_asset", "layout_reference", "style_reference"]
          },
          "label": { "type": "string" },
          "notes": { "type": "string" },
          "uploaded_at": { "type": "string" }
        },
        "required": ["filename", "role"]
      }
    },
    "created_at": {
      "type": "string",
      "description": "ISO timestamp of site creation"
    },
    "netlify_site_id": {
      "type": "string",
      "description": "Netlify site UUID for redeployments"
    },
    "deploy_provider": {
      "type": "string",
      "enum": ["netlify", "cloudflare", "vercel"],
      "description": "Deployment provider used"
    },
    "brand_health": {
      "type": "object",
      "description": "Brand health metrics computed by scanBrandHealth()",
      "properties": {
        "score": { "type": "number" },
        "slots": { "type": "object" },
        "last_scan": { "type": "string" }
      }
    },
    "media_specs": {
      "type": "object",
      "description": "Image slot registry — maps slot IDs to metadata (page, role, status, dimensions, src)",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string" },
          "dimensions": { "type": "string" },
          "src": { "type": "string" }
        }
      }
    },
    "slot_mappings": {
      "type": "object",
      "description": "Persistent slot-to-image mappings that survive rebuilds",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "src": { "type": "string" },
          "provider": { "type": "string" },
          "credit": { "type": "string" },
          "query": { "type": "string" }
        }
      }
    },
    "tech_recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tech stack recommendations generated from brief analysis"
    },
    "slot_queries": {
      "type": "object",
      "description": "Per-slot preferred stock photo search queries. Keys are slot_ids, values are search query strings.",
      "additionalProperties": { "type": "string" }
    },
    "content": {
      "type": "object",
      "description": "Structured content fields per page, extracted from rendered HTML. Keys are page filenames.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_id": { "type": "string", "description": "Unique field identifier: {page}-{type}-{n}" },
                "type": { "type": "string", "enum": ["text", "richtext", "phone", "email", "address", "hours", "link", "image", "price", "testimonial", "list"] },
                "value": { "description": "Field value — string for simple types, object for composite types" },
                "element": { "type": "string", "description": "HTML element tag (h1, p, a, etc.)" },
                "scope": { "type": "string", "enum": ["local", "global"], "description": "local = this page only, global = appears across pages" },
                "editable": { "type": "boolean" },
                "render_targets": {
                  "type": "array",
                  "description": "All DOM locations where this field's value renders",
                  "items": {
                    "type": "object",
                    "properties": {
                      "page": { "type": "string", "description": "Page filename, or * for all pages" },
                      "selector": { "type": "string", "description": "CSS selector to locate the element" },
                      "attribute": { "type": "string", "description": "Which attribute to update (textContent, href, src, etc.)" },
                      "transform": { "type": "string", "description": "Transform name (display, tel_href, mailto_href, e164, etc.)" }
                    }
                  }
                }
              },
              "required": ["field_id", "type", "value"]
            }
          }
        }
      }
    },
    "sections": {
      "type": "object",
      "description": "Section-level metadata per page, including component references. Keys are page filenames.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "section_id": { "type": "string", "description": "Unique section ID: {page}-{type}-{n}" },
            "section_type": { "type": "string" },
            "order": { "type": "integer" },
            "component_ref": { "type": "string", "description": "Library component reference (if imported)" },
            "component_version": { "type": "string" },
            "component_instance_id": { "type": "string", "description": "Site-scoped instance ID: {tag}-{ref}-{n}" },
            "imported_at": { "type": "string", "format": "date-time" },
            "diverged_at": { "type": "string", "format": "date-time", "description": "Set when instance is edited after import" },
            "overrides": { "type": "object", "description": "CSS variable and content field overrides from library defaults" }
          }
        }
      }
    }
  }
}
