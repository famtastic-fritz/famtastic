{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FAMtastic Site Spec",
  "description": "Specification for a site built by the FAMtastic site orchestrator",
  "type": "object",
  "required": ["site_name", "tag", "colors", "pages"],
  "properties": {
    "site_name": {
      "type": "string",
      "description": "Display name of the site"
    },
    "tag": {
      "type": "string",
      "pattern": "^site-[a-z0-9-]+$",
      "description": "Unique tag identifier (must start with site-)"
    },
    "business_type": {
      "type": "string",
      "description": "Type of business/purpose (e.g. event, restaurant, portfolio)"
    },
    "colors": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      },
      "required": ["primary"]
    },
    "pages": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "List of pages to generate (e.g. home, about, services, contact). Each becomes a separate HTML file."
    },
    "features": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Features to include (hero_banner, contact_form, countdown_timer, etc.)"
    },
    "tone": {
      "type": "string",
      "description": "Desired tone/voice for the copy"
    },
    "fonts": {
      "type": "object",
      "properties": {
        "heading": { "type": "string" },
        "body": { "type": "string" }
      }
    },
    "assets_needed": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Visual assets to generate (logo, hero_banner, etc.)"
    },
    "state": {
      "type": "string",
      "enum": ["drafting", "incubating", "blueprint", "prototype", "validating", "deployed"],
      "description": "Current lifecycle state"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "deployed_url": {
      "type": "string",
      "description": "Live URL after deployment"
    },
    "deployed_at": {
      "type": "string",
      "description": "ISO timestamp of last deployment"
    },
    "domain": {
      "type": "string",
      "description": "Custom domain (registered via GoDaddy reseller)"
    },
    "design_brief": {
      "type": "object",
      "description": "Structured design brief created during planning mode",
      "properties": {
        "goal": { "type": "string" },
        "audience": { "type": "string" },
        "tone": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visual_direction": {
          "type": "object",
          "properties": {
            "layout": { "type": "string" },
            "typography": { "type": "string" },
            "color_usage": { "type": "string" },
            "motion": { "type": "string" },
            "density": { "type": "string" }
          }
        },
        "content_priorities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_have_sections": {
          "type": "array",
          "items": { "type": "string" }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approved": {
          "type": "boolean",
          "description": "Whether the user has approved this brief"
        }
      }
    },
    "design_decisions": {
      "type": "array",
      "description": "Log of durable design decisions made during the build",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["typography", "layout", "color", "content", "interaction", "structure"]
          },
          "decision": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["approved", "rejected", "superseded"]
          }
        },
        "required": ["timestamp", "category", "decision", "status"]
      }
    },
    "uploaded_assets": {
      "type": "array",
      "description": "Assets uploaded by the user with intent metadata",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["image", "text", "prompt", "logo", "screenshot"]
          },
          "role": {
            "type": "string",
            "enum": ["inspiration", "content", "brand_asset", "layout_reference", "style_reference"]
          },
          "label": { "type": "string" },
          "notes": { "type": "string" },
          "uploaded_at": { "type": "string" }
        },
        "required": ["filename", "role"]
      }
    },
    "created_at": {
      "type": "string",
      "description": "ISO timestamp of site creation"
    },
    "netlify_site_id": {
      "type": "string",
      "description": "Netlify site UUID for redeployments"
    },
    "deploy_provider": {
      "type": "string",
      "enum": ["netlify", "cloudflare", "vercel"],
      "description": "Deployment provider used"
    },
    "brand_health": {
      "type": "object",
      "description": "Brand health metrics computed by scanBrandHealth()",
      "properties": {
        "score": { "type": "number" },
        "slots": { "type": "object" },
        "last_scan": { "type": "string" }
      }
    },
    "media_specs": {
      "type": "object",
      "description": "Image slot registry — maps slot IDs to metadata (page, role, status, dimensions, src)",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "page": { "type": "string" },
          "role": { "type": "string" },
          "status": { "type": "string" },
          "dimensions": { "type": "string" },
          "src": { "type": "string" }
        }
      }
    },
    "slot_mappings": {
      "type": "object",
      "description": "Persistent slot-to-image mappings that survive rebuilds",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "src": { "type": "string" },
          "provider": { "type": "string" },
          "credit": { "type": "string" },
          "query": { "type": "string" }
        }
      }
    },
    "tech_recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tech stack recommendations generated from brief analysis"
    }
  }
}
