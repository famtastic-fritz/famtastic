# Copy to .env and fill in only what you need. With NOTHING set, the system runs
# fully offline in stub mode: no network calls, no real spend, modeled costs only.

# Real model calls via OpenRouter (leave blank to stay in offline stub mode):
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional overrides:
# FACTORY_MAX_CONCURRENCY=4
# PORT=4178
