# ─── Agent Factory environment (copy to .env and fill what you have) ───
# EVERYTHING is optional. With nothing set, the system runs fully offline in
# stub mode: model calls return deterministic synthetic output and costs are
# *estimated*, never charged.

# OpenRouter-style unified model gateway. If present, the router MAY make real
# calls for tiers configured as "live". If absent, every tier is stubbed.
OPENROUTER_API_KEY=

# Local model endpoint (e.g. Ollama / llama.cpp). Used for the $0 "local" tier.
# If unreachable, the local tier also falls back to stub.
LOCAL_MODEL_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1:8b

# ─── Business pipeline secrets (documented, NOT used for live spend) ───
# These are placeholders for the FAMtastic deal-finding product pipeline. The
# system records that they would be needed; it never moves money or sends mail.
PAYPAL_BUSINESS_EMAIL=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
GODADDY_API_KEY=
GODADDY_API_SECRET=
OUTREACH_FROM_EMAIL=deals@yourdomain.com

# Hard safety switch. Must be explicitly set to "1" before ANY live model call.
# Default unset = offline/stub only.
FACTORY_ALLOW_LIVE_CALLS=
