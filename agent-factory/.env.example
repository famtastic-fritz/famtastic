# Copy to .env and fill in to enable REAL model calls. Leave unset to run fully
# offline with stubbed models (the default, and what the demo uses).

# OpenRouter-style key. If absent, models.py stubs every call deterministically.
OPENROUTER_API_KEY=

# Master switch. Even with a key present, calls stay mocked unless this is 1.
# This is a deliberate double-safety so the sandbox never spends by accident.
FACTORY_LIVE=0

# Optional override of the OpenRouter base URL (only used when FACTORY_LIVE=1).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
