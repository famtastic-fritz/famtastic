# Copy to .env and fill in to enable REAL model calls. Leave blank to run fully
# offline with stubbed (mock) model responses. The sandbox never spends money on
# its own; supplying a key only takes effect if you also set FACTORY_LIVE=1.

# OpenRouter-style API key (https://openrouter.ai). Optional.
OPENROUTER_API_KEY=

# Master switch. "0" (default) = stub all model calls, no network, no spend.
# "1" = allow live calls IF OPENROUTER_API_KEY is set. Even then there is a
# hard per-run spend cap enforced in src/router.py.
FACTORY_LIVE=0

# Hard ceiling on estimated USD per run. The router refuses to exceed this.
FACTORY_MAX_RUN_USD=1.00

# --- Business pipeline integrations (mocked until filled; see SETUP.md) ---
# PayPal business account (collection of payment). Mocked in sandbox.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# GoDaddy custom email / sending (campaigns, contacting). Mocked in sandbox.
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_SENDING_DOMAIN=
