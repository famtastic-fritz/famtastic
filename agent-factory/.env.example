# Copy to .env and fill in to enable LIVE model calls. Leave unset to run offline.
#
# By default the factory runs FULLY OFFLINE using a deterministic stub in
# src/llm.py — no key required, no spend. To use real models you must do BOTH:
#   1. set a real key below
#   2. set AGENT_FACTORY_LIVE=1
#
# Even with a key present, AGENT_FACTORY_LIVE must be 1 or the stub is used.

OPENROUTER_API_KEY=
AGENT_FACTORY_LIVE=0

# Optional: OpenRouter base url (default https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
