# Copy this file to `.env` and fill in real values to go live.
# With NO .env present, the factory runs fully offline using stubbed model calls.

# --- Model layer (OpenRouter-style) ---------------------------------------
# Get a key at https://openrouter.ai/keys . Leave blank to stay offline.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Master switch. Even with a key present, calls stay STUBBED unless this is true.
# This is the single guardrail that prevents accidental spend.
FACTORY_LIVE_CALLS=false

# --- Payment / business rails -------------------------------------------------
# PayPal is used two ways:
#   1) as TEXT in generated business docs (always safe), and
#   2) by the paypal_invoice_draft action to create DRAFT invoices only.
# DRAFTS ARE NEVER SENT and NO money moves. See paypal.py + SANDBOX.md.
PAYPAL_BUSINESS_EMAIL=
PAYPAL_INVOICER_NAME=FAMtastic Designs
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox (default, recommended) or live. Controls which PayPal API host is used.
PAYPAL_ENV=sandbox
# Master switch for real draft creation. Even with creds, drafts are only created
# in PayPal when this is true AND config.json "paypal_live" is true.
FACTORY_LIVE_PAYPAL=false

GODADDY_DOMAIN=
GODADDY_OUTREACH_EMAIL=
