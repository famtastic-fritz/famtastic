# ─────────────────────────────────────────────────────────────────────────────
# agent-factory environment. Copy to `.env` and fill in to go live.
# EVERYTHING runs fully offline with this file ABSENT — keys are optional.
# ─────────────────────────────────────────────────────────────────────────────

# --- Model layer (OpenRouter-style) ---------------------------------------
# If unset, src/llm.py returns deterministic offline mock completions and the
# whole system still runs end-to-end. Set this to make REAL routed calls.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Proof task: FAMtastic Designs sales pipeline -------------------------
# These are MOCK placeholders. The factory never actually calls them; the
# business-model task documents exactly where each one plugs in. Fill later.

# PayPal Business (invoicing / payment collection)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox            # sandbox | live

# GoDaddy (custom sending domain + mailbox for outreach)
GODADDY_DOMAIN=famtasticdesigns.com
GODADDY_OUTREACH_FROM=hello@famtasticdesigns.com
GODADDY_SMTP_HOST=smtpout.secureserver.net
GODADDY_SMTP_USER=
GODADDY_SMTP_PASS=
