# Isolated env
.venv/
__pycache__/
*.pyc

# Separate git-dir pointer target is outside the tree; ignore local runtime junk
.factory-git/

# Runtime data & logs are regenerated by the system; keep the dirs, drop contents
data/*.db
data/*.db-wal
data/*.db-shm
data/state.json

# Minted (generated) worker instances — regenerated on demand by the factory
workers/worker_*_*.py

# Local secrets
.env

# Runtime exhaust (regenerated on every run; sample copies live in proof/)
logs/*.log
COSTS.log
dashboard/index.html
