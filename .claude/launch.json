{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "famtastic-studio",
      "runtimeExecutable": "node",
      "runtimeArgs": ["site-studio/server.js"],
      "port": 3334
    },
    {
      "name": "street-family-reunion",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "sites/site-street-family-reunion/dist"],
      "autoPort": true
    },
    {
      "name": "ncs-v2",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8899", "--directory", "/tmp/ncs-v2"],
      "port": 8899
    }
  ]
}
