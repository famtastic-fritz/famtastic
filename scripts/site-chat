#!/usr/bin/env bash
set -euo pipefail

# site-chat — Launch Site Studio (chat UI + preview server)
# Usage: scripts/site-chat <tag> [--no-open]

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/.."

TAG="${1:?Usage: site-chat <tag> [--no-open]}"
NO_OPEN="${2:-}"
STUDIO_PORT="${STUDIO_PORT:-3334}"
PREVIEW_PORT="${PREVIEW_PORT:-3333}"

# Ensure tag starts with site-
[[ "$TAG" == site-* ]] || TAG="site-$TAG"

SITE_DIR="./sites/$TAG"
DIST="$SITE_DIR/dist"

# Initialize site if it doesn't exist
if [ ! -d "$SITE_DIR" ]; then
  echo "[chat] No site found for $TAG, initializing..."
  ./scripts/orchestrator-site "$TAG" --skip-ai
fi

# Track PIDs for cleanup
PIDS=()
cleanup() {
  echo ""
  echo "[chat] Shutting down..."
  for pid in "${PIDS[@]}"; do
    kill "$pid" 2>/dev/null || true
  done
  wait 2>/dev/null || true
  echo "[chat] Done."
}
trap cleanup EXIT INT TERM

# Start site-studio (includes built-in preview server)
#
# IMPORTANT: launch via `zsh -l -c` so ~/.zshrc is sourced and every API
# key exported there (ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY,
# PINECONE_API_KEY, NETLIFY_AUTH_TOKEN, etc.) is in the server's env.
# Without the login shell, studios started from non-interactive contexts
# (cron, nohup, background scripts) inherit a stripped env and the brain
# verifier reports the keys as missing. The login shell is the default —
# no manual trick required.
echo "[chat] Starting Site Studio on port $STUDIO_PORT (preview on $PREVIEW_PORT)..."
zsh -l -c "[ -f ~/.zshrc ] && source ~/.zshrc; SITE_TAG='$TAG' STUDIO_PORT='$STUDIO_PORT' PREVIEW_PORT='$PREVIEW_PORT' exec node '$SCRIPT_DIR/../site-studio/server.js'" &
PIDS+=($!)
sleep 1

echo ""
echo "============================================"
echo "  FAMtastic Site Studio"
echo "  Chat:    http://localhost:$STUDIO_PORT"
echo "  Preview: http://localhost:$PREVIEW_PORT"
echo "  Site:    $TAG"
echo "============================================"
echo ""

# Open browser unless --no-open
if [ "$NO_OPEN" != "--no-open" ]; then
  if command -v open >/dev/null 2>&1; then
    open "http://localhost:$STUDIO_PORT"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "http://localhost:$STUDIO_PORT"
  fi
fi

echo "[chat] Press Ctrl+C to stop"

# Wait for processes
wait
