#!/usr/bin/env python3
"""firefly-generate — Generate images via Adobe Firefly API.

Usage:
  firefly-generate --prompt "..." --output path/to/image.jpg [--style-ref URL] [--width 2048] [--height 2048]
  firefly-generate --batch batch.json --output-dir path/to/dir/

Environment:
  FIREFLY_CLIENT_ID     — Adobe Developer Console client ID
  FIREFLY_CLIENT_SECRET — Adobe Developer Console client secret

Batch JSON format:
  [
    { "prompt": "...", "filename": "img1.jpg" },
    { "prompt": "...", "filename": "img2.jpg", "style_ref": "https://..." }
  ]
"""

import os, sys, json, time, urllib.request, urllib.parse, ssl

IMS_TOKEN_URL = "https://ims-na1.adobelogin.com/ims/token/v3"
FIREFLY_API_URL = "https://firefly-api.adobe.io/v3/images/generate-async"
FIREFLY_SYNC_URL = "https://firefly-api.adobe.io/v2/images/generate"

def get_access_token():
    client_id = os.environ.get("FIREFLY_CLIENT_ID")
    client_secret = os.environ.get("FIREFLY_CLIENT_SECRET")
    if not client_id or not client_secret:
        print("ERROR: FIREFLY_CLIENT_ID and FIREFLY_CLIENT_SECRET must be set", file=sys.stderr)
        sys.exit(1)
    data = urllib.parse.urlencode({
        "grant_type": "client_credentials",
        "client_id": client_id,
        "client_secret": client_secret,
        "scope": "openid,AdobeID,session,additional_info,read_organizations,firefly_api,ff_apis"
    }).encode()
    req = urllib.request.Request(IMS_TOKEN_URL, data=data, method="POST")
    req.add_header("Content-Type", "application/x-www-form-urlencoded")
    ctx = ssl.create_default_context()
    resp = urllib.request.urlopen(req, context=ctx)
    token_data = json.loads(resp.read())
    return token_data["access_token"]

def generate_image(prompt, access_token, client_id, width=2048, height=2048, style_ref=None):
    body = {
        "prompt": prompt,
        "n": 1,
        "size": {"width": width, "height": height},
        "contentClass": "photo"
    }
    if style_ref:
        body["styles"] = {
            "referenceImage": {"source": {"url": style_ref}}
        }
    data = json.dumps(body).encode()
    req = urllib.request.Request(FIREFLY_SYNC_URL, data=data, method="POST")
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json")
    req.add_header("x-api-key", client_id)
    req.add_header("Authorization", f"Bearer {access_token}")
    ctx = ssl.create_default_context()
    start = time.time()
    try:
        resp = urllib.request.urlopen(req, context=ctx, timeout=120)
        result = json.loads(resp.read())
        elapsed = time.time() - start
        return result, elapsed
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        print(f"ERROR: HTTP {e.code}: {body}", file=sys.stderr)
        return None, time.time() - start

def download_image(url, output_path):
    ctx = ssl.create_default_context()
    req = urllib.request.Request(url)
    resp = urllib.request.urlopen(req, context=ctx, timeout=60)
    os.makedirs(os.path.dirname(output_path) or ".", exist_ok=True)
    with open(output_path, "wb") as f:
        f.write(resp.read())
    size = os.path.getsize(output_path)
    print(f"  Saved: {output_path} ({size // 1024} KB)")
    return size

def log_telemetry(data):
    """Log media operation to Studio telemetry endpoint (best-effort)."""
    try:
        telemetry_url = os.environ.get("STUDIO_URL", "http://localhost:3334") + "/api/media/log"
        body = json.dumps(data).encode()
        req = urllib.request.Request(telemetry_url, data=body, method="POST")
        req.add_header("Content-Type", "application/json")
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        pass  # Telemetry is best-effort — don't fail the generation

def main():
    import argparse
    parser = argparse.ArgumentParser(description="Generate images via Adobe Firefly API")
    parser.add_argument("--prompt", help="Text prompt for image generation")
    parser.add_argument("--output", help="Output file path")
    parser.add_argument("--style-ref", help="URL of style reference image")
    parser.add_argument("--width", type=int, default=2048, help="Image width (default 2048)")
    parser.add_argument("--height", type=int, default=2048, help="Image height (default 2048)")
    parser.add_argument("--batch", help="Path to batch JSON file")
    parser.add_argument("--output-dir", help="Output directory for batch")
    args = parser.parse_args()

    client_id = os.environ.get("FIREFLY_CLIENT_ID")
    if not client_id:
        print("ERROR: FIREFLY_CLIENT_ID not set. Get credentials at:")
        print("  https://developer.adobe.com/firefly-services/docs/firefly-api/guides/")
        sys.exit(1)

    print("Authenticating with Adobe IMS...")
    token = get_access_token()
    print("  Token obtained.")

    if args.batch:
        with open(args.batch) as f:
            items = json.load(f)
        out_dir = args.output_dir or "."
        os.makedirs(out_dir, exist_ok=True)
        results = []
        for i, item in enumerate(items):
            print(f"\n[{i+1}/{len(items)}] Generating: {item['prompt'][:60]}...")
            result, elapsed = generate_image(
                item["prompt"], token, client_id,
                args.width, args.height,
                item.get("style_ref")
            )
            if result and result.get("outputs"):
                url = result["outputs"][0]["image"]["url"]
                # Codex review: sanitize filename to prevent path traversal
                safe_filename = os.path.basename(item.get("filename", f"image-{i+1}.jpg"))
                outpath = os.path.join(out_dir, safe_filename)
                size = download_image(url, outpath)
                results.append({"file": outpath, "elapsed": elapsed, "size": size, "success": True})
                # Codex review: log telemetry for batch items too
                log_telemetry({
                    "provider": "adobe-firefly",
                    "model": "firefly-image-3",
                    "operation": "batch",
                    "cost_usd": 0,
                    "credits_used": 1,
                    "generation_time_seconds": round(elapsed, 1),
                    "file_size_bytes": size,
                    "prompt": item["prompt"][:200],
                    "style_reference_used": bool(item.get("style_ref")),
                    "batch_size": len(items),
                })
            else:
                results.append({"file": item.get("filename"), "elapsed": elapsed, "success": False})
                print(f"  FAILED")
        print(f"\nBatch complete: {sum(1 for r in results if r['success'])}/{len(results)} succeeded")
        return

    if not args.prompt or not args.output:
        parser.print_help()
        sys.exit(1)

    print(f"Generating: {args.prompt[:80]}...")
    result, elapsed = generate_image(args.prompt, token, client_id, args.width, args.height, args.style_ref)
    if result and result.get("outputs"):
        url = result["outputs"][0]["image"]["url"]
        size = download_image(url, args.output)
        print(f"  Generated in {elapsed:.1f}s")
        log_telemetry({
            "provider": "adobe-firefly",
            "model": "firefly-image-3",
            "operation": "generate",
            "cost_usd": 0,
            "credits_used": 1,
            "generation_time_seconds": round(elapsed, 1),
            "file_size_bytes": size,
            "resolution": f"{args.width}x{args.height}",
            "prompt": args.prompt,
            "style_reference_used": bool(args.style_ref),
        })
    else:
        print("Generation failed.", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
