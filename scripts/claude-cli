#!/usr/bin/env bash
set -euo pipefail
. scripts/lib/hub-common 2>/dev/null || true
AK="$(secret_get ANTHROPIC_API_KEY || true)"
[ -n "$AK" ] || { echo "ERR: ANTHROPIC_API_KEY not set (use repo SOPS)"; exit 1; }
export ANTHROPIC_API_KEY="$AK"
DEFAULT_MODEL="$(yq -r .claude.model config/agents/defaults.yaml 2>/dev/null || echo claude-sonnet-4-20250514)"
MODEL="${MODEL:-$DEFAULT_MODEL}"
if [ $# -gt 0 ]; then PROMPT="$*"; else PROMPT="$(cat)"; fi
python3 - "$MODEL" <<'PY'
import sys, os, anthropic
model=sys.argv[1]
client=anthropic.Anthropic(api_key=os.environ["ANTHROPIC_API_KEY"])
msg=client.messages.create(model=model,max_tokens=512,messages=[{"role":"user","content":os.read(0,10_000_000).decode()}])
print(msg.content[0].text)
PY