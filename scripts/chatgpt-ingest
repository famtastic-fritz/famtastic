#!/usr/bin/env bash
set -euo pipefail
TAG="${1:-latest-convo}"
TYPE="${2:-md}"
FILE="${3:-/dev/stdin}"
ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/famtastic/agent-hub/sources/chatgpt"
mkdir -p "$ROOT"

# Prep log file
LOG="$ROOT/$TAG.jsonl"
TS="$(date -u +%FT%TZ)"
ID=$(uuidgen)

# v0.5+v0.6 Features: Auto-promotion and workflow rules
check_promotion_rules() {
  local tag="$1"
  case "$tag" in
    resume-*|job-*) echo "promote" ;;
    meeting-*|notes-*) echo "promote" ;;
    site-*|project-*) echo "promote" ;;
    *) echo "draft" ;;
  esac
}

check_workflow_rules() {
  local tag="$1"
  case "$tag" in
    resume-*|job-*) echo "orchestrator-resume" ;;
    site-*) echo "orchestrator-site" ;;
    *) echo "none" ;;
  esac
}

promote_file() {
  local draft_file="$1"
  local promoted_file="${draft_file%.draft.md}.md"

  if [ -f "$draft_file" ]; then
    mv "$draft_file" "$promoted_file"
    echo "[promote] $draft_file → $promoted_file"

    # Log promotion
    local promo_id=$(uuidgen)
    jq -c -n --arg id "$promo_id" --arg at "$(date -u +%FT%TZ)" --arg tag "$TAG" --arg from "$draft_file" --arg to "$promoted_file" \
      '{id:$id,at:$at,agent:"chatgpt",tag:$tag,action:"promote",from:$from,to:$to}' \
      >> "$LOG"

    echo "$promoted_file"
  else
    echo "$draft_file"
  fi
}

trigger_workflow() {
  local tag="$1"
  local workflow="$2"
  local file="$3"

  if [ "$workflow" != "none" ]; then
    echo "[auto-workflow] triggering $workflow for $tag"
    local workflow_id=$(uuidgen)

    # Log workflow trigger
    jq -c -n --arg id "$workflow_id" --arg at "$(date -u +%FT%TZ)" --arg tag "$tag" --arg workflow "$workflow" --arg trigger_file "$file" \
      '{id:$id,at:$at,agent:"chatgpt",tag:$tag,action:"workflow_trigger",workflow:$workflow,trigger_file:$trigger_file}' \
      >> "$LOG"

    case "$workflow" in
      orchestrator-resume)
        if [ -x "scripts/orchestrator-resume" ]; then
          "scripts/orchestrator-resume" "$tag" &
          echo "[auto-workflow] resume orchestrator started for $tag"
        else
          echo "[auto-workflow] warning: orchestrator-resume not found"
        fi ;;
      orchestrator-site)
        echo "[auto-workflow] site orchestrator would run for $tag (not implemented yet)"
        ;;
      *)
        echo "[auto-workflow] unknown workflow: $workflow"
        ;;
    esac
  fi
}

case "$TYPE" in
  md)
    OUT="docs/${TAG}.draft.md"
    mkdir -p docs
    cat "$FILE" > "$OUT"

    # Log initial ingest
    jq -c -n --arg id "$ID" --arg at "$TS" --arg tag "$TAG" --arg out "$OUT" \
      '{id:$id,at:$at,agent:"chatgpt",tag:$tag,messages:[{role:"assistant",content:"ingested markdown"}],outputs:[$out]}' \
      >> "$LOG"
    echo "[ingest] markdown → $OUT"

    # v0.5: Check auto-promotion rules
    PROMOTION_RULE=$(check_promotion_rules "$TAG")
    if [ "$PROMOTION_RULE" = "promote" ]; then
      FINAL_FILE=$(promote_file "$OUT")
      echo "[auto-promote] $TAG matches trusted pattern"

      # v0.6: Check auto-workflow rules
      WORKFLOW_RULE=$(check_workflow_rules "$TAG")
      trigger_workflow "$TAG" "$WORKFLOW_RULE" "$FINAL_FILE"
    else
      echo "[safety] $TAG stays as draft - manual promotion required"
    fi ;;
  json)
    OUT="convos/canonical/${TAG}.json"
    mkdir -p convos/canonical
    if jq . "$FILE" > /tmp/validate_json.tmp 2>/dev/null; then
      mv /tmp/validate_json.tmp "$OUT"
      jq -c -n --arg id "$ID" --arg at "$TS" --arg tag "$TAG" --arg out "$OUT" \
        '{id:$id,at:$at,agent:"chatgpt",tag:$tag,messages:[{role:"assistant",content:"ingested json"}],outputs:[$out]}' \
        >> "$LOG"
      echo "[ingest] json → $OUT"
    else
      echo "[ingest-error] invalid JSON input for $TAG"
      jq -c -n --arg id "$ID" --arg at "$TS" --arg tag "$TAG" --arg err "invalid JSON input" \
        '{id:$id,at:$at,agent:"chatgpt",tag:$tag,error:$err}' \
        >> "$LOG"
      rm -f /tmp/validate_json.tmp
      exit 3
    fi ;;
  *)
    echo "[error] unknown ingest type: $TYPE"; exit 2 ;;
esac