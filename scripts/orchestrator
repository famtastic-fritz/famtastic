#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-help}"; shift || true
case "$cmd" in
  read-summary)
    mode="${1:-}"; shift || true
    if [ "$mode" = "--tts" ]; then
      TAG="${1:-latest-convo}"
      # Find most recent summary for tag
      FILE=$(ls -t convos/summaries/${TAG}__*.md 2>/dev/null | head -n1 || true)
      if [ -z "$FILE" ]; then
        echo "[error] no summary found for $TAG"; exit 4;
      fi
      echo "[orchestrator] reading $FILE via TTS..."
      TEXT=$(cat "$FILE")
      ./scripts/tts-agent "$TAG-summary" "$TEXT"
    else
      echo "Usage: scripts/orchestrator read-summary --tts <tag>"; exit 2;
    fi;;
  build-site)
    # Legacy POC site building functionality
    SPEC="${1:-spec.json}"
    RUN_DIR="./sites/poc-site"
    mkdir -p "$RUN_DIR"

    echo "[step1] Using Claude for copy..."
    echo "<h1>Welcome to POC Site</h1>" > "$RUN_DIR/index.html"

    echo "[step2] Using Gemini for layout..."
    echo "<p>This is a demo page in blue and white.</p>" >> "$RUN_DIR/index.html"

    echo "[step3] Using Codex for wiring..."
    echo "<form><input type='text' placeholder='Your email'><button>Send</button></form>" >> "$RUN_DIR/index.html"

    echo "[done] Site ready at $RUN_DIR/index.html";;
  *)
    echo "Usage: scripts/orchestrator {read-summary|build-site}"; exit 2;;
esac