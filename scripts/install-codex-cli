#!/usr/bin/env bash
set -euo pipefail
has(){ command -v "$1" >/dev/null 2>&1; }
ok(){ printf "\033[32m✔ %s\033[0m\n" "$*"; }
die(){ printf "\033[31m✖ %s\033[0m\n" "$*" >&2; exit 1; }
if has codex; then ok "codex present: $(codex --version 2>/dev/null | head -n1)"; exit 0; fi
has brew || die "Homebrew required to install codex"
brew install codex
ok "installed codex"