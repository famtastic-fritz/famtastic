#!/usr/bin/env bash
set -euo pipefail
HOST="${LITELLM_HOST:-127.0.0.1}"
PORT="${LITELLM_PORT:-8089}"
MODEL="${MODEL:-code-free}"   # ONLY the free lane
if [ $# -gt 0 ]; then PROMPT="$*"; else PROMPT="$(cat)"; fi
# ensure LiteLLM (repo-secrets) is up
if ! curl -fsS "http://$HOST:$PORT/" >/dev/null 2>&1; then
  ./scripts/litellm-serve >/tmp/litellm.out 2>&1 & echo $! >/tmp/litellm.pid
  sleep 3
fi
curl -fsS -H "Content-Type: application/json" -X POST "http://$HOST:$PORT/v1/chat/completions" \
  -d "$(printf '{"model":"%s","messages":[{"role":"user","content":%s}]}' "$MODEL" "$(python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))' <<<"$PROMPT") )" \
  | python3 - <<'PY'
import sys, json
j=json.load(sys.stdin)
try:
    print(j["choices"][0]["message"]["content"])
except Exception:
    print(json.dumps(j, indent=2))
PY
# stop if we started it
if [ -f /tmp/litellm.pid ]; then kill "$(cat /tmp/litellm.pid)" >/dev/null 2>&1 || true; rm -f /tmp/litellm.pid; fi