#!/usr/bin/env bash
set -euo pipefail
has(){ command -v "$1" >/dev/null 2>&1; }
has codex || { echo "ERR: codex CLI not installed. Run: ./scripts/install-codex-cli" >&2; exit 1; }
PROMPT="${*:-}"; [ -n "$PROMPT" ] || PROMPT="$(cat)"
# Prefer non-interactive exec; fallback to proto; else pass-through
if out="$(codex exec "$PROMPT" 2>/dev/null)"; then printf "%s\n" "$out"
elif out="$(printf "%s" "$PROMPT" | codex proto 2>/dev/null)"; then printf "%s\n" "$out"
else codex "$PROMPT"; fi