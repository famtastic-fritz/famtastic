#!/usr/bin/env bash
set -euo pipefail
. "$(dirname "$0")/_cj_common.sh"

tag="${1:?usage: cj-chat-insert <tag> <role> <text...>}"
role="${2:?role one of: user|assistant|system}"
shift 2
text="${*:?message text required}"


canon="$CJ_DATA_ROOT/convos/canonical/$tag.json"
[ -f "$canon" ] || printf '%s\n' '{"messages":[],"tag":"'