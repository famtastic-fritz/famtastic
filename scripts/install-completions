#!/usr/bin/env bash

# Install bash and zsh completions for fam-hub CLI

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HUB_ROOT="$(dirname "$SCRIPT_DIR")"

install_bash_completion() {
    local completion_file="$HUB_ROOT/completions/fam-hub.bash"
    local target_dirs=(
        "/usr/local/etc/bash_completion.d"
        "/etc/bash_completion.d"
        "$HOME/.bash_completion.d"
    )

    echo "Installing bash completion..."

    # Try system directories first
    for dir in "${target_dirs[@]}"; do
        if [[ -d "$dir" && -w "$dir" ]] 2>/dev/null; then
            cp "$completion_file" "$dir/fam-hub"
            echo "✓ Installed bash completion to $dir/fam-hub"
            return 0
        fi
    done

    # Fallback: create local directory and add source to .bashrc
    mkdir -p "$HOME/.bash_completion.d"
    cp "$completion_file" "$HOME/.bash_completion.d/fam-hub"

    # Add sourcing to .bashrc if not already present
    local bashrc="$HOME/.bashrc"
    if [[ -f "$bashrc" ]] && ! grep -q "\.bash_completion\.d" "$bashrc"; then
        echo "" >> "$bashrc"
        echo "# Load custom bash completions" >> "$bashrc"
        echo "for completion in ~/.bash_completion.d/*; do" >> "$bashrc"
        echo "    [[ -r \"\$completion\" ]] && source \"\$completion\"" >> "$bashrc"
        echo "done" >> "$bashrc"
        echo "✓ Added completion loading to ~/.bashrc"
    fi

    echo "✓ Installed bash completion to ~/.bash_completion.d/fam-hub"
}

install_zsh_completion() {
    local completion_file="$HUB_ROOT/completions/fam-hub.zsh"
    local fpath_dirs=(
        "/usr/local/share/zsh/site-functions"
        "/usr/share/zsh/site-functions"
        "$HOME/.zsh/completions"
    )

    echo "Installing zsh completion..."

    # Try system directories first
    for dir in "${fpath_dirs[@]}"; do
        if [[ -d "$dir" && -w "$dir" ]] 2>/dev/null; then
            cp "$completion_file" "$dir/_fam-hub"
            echo "✓ Installed zsh completion to $dir/_fam-hub"
            return 0
        fi
    done

    # Fallback: create local directory and add to fpath
    mkdir -p "$HOME/.zsh/completions"
    cp "$completion_file" "$HOME/.zsh/completions/_fam-hub"

    # Add to fpath in .zshrc if not already present
    local zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]] && ! grep -q "\.zsh/completions" "$zshrc"; then
        echo "" >> "$zshrc"
        echo "# Add custom completions to fpath" >> "$zshrc"
        echo "fpath=(~/.zsh/completions \$fpath)" >> "$zshrc"
        echo "autoload -U compinit && compinit" >> "$zshrc"
        echo "✓ Added completion path to ~/.zshrc"
    fi

    echo "✓ Installed zsh completion to ~/.zsh/completions/_fam-hub"
}

main() {
    echo "Installing fam-hub CLI completions..."

    # Detect current shell
    if [[ -n "${BASH_VERSION:-}" ]]; then
        install_bash_completion
    elif [[ -n "${ZSH_VERSION:-}" ]]; then
        install_zsh_completion
    else
        # Install both if shell is unknown
        echo "Shell detection failed, installing both bash and zsh completions"
        install_bash_completion
        install_zsh_completion
    fi

    echo ""
    echo "Completion installation complete!"
    echo "Restart your shell or run 'source ~/.bashrc' or 'source ~/.zshrc' to enable completions."
}

main "$@"