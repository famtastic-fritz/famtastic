#!/usr/bin/env bash
# fam-hub — Unified CLI for FAMtastic

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR always points to the real scripts/ directory,
# not the symlink location (e.g. ~/.famtastic-bin/).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
HUB_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$HUB_ROOT"

CMD="${1:-help}"
SUBCMD="${2:-}"

case "$CMD" in

  # --- Site Factory ---
  site)
    SITECMD="${2:-help}"
    case "$SITECMD" in
      new)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site new <tag>"
          echo "  Tag should start with 'site-' (e.g., site-reunion)"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        shift 3 || true
        "$SCRIPT_DIR/site-chat" "$TAG" "$@"
        ;;
      chat)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site chat <tag>"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        shift 3 || true
        "$SCRIPT_DIR/site-chat" "$TAG" "$@"
        ;;
      brainstorm)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site brainstorm <tag>"
          echo "  Opens a brainstorm session for the given site (no HTML output)"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        shift 3 || true
        "$SCRIPT_DIR/site-brainstorm" "$TAG" "$@"
        ;;
      preview)
        TAG="${3:-}"
        PORT="${4:-3333}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site preview <tag> [port]"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        "$SCRIPT_DIR/site-preview" "$TAG" "$PORT"
        ;;
      build)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site build <tag> [--template name]"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        shift 3 || true
        "$SCRIPT_DIR/orchestrator-site" "$TAG" "$@"
        ;;
      list|status)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo ""
          echo "FAMtastic Site Portfolio"
          echo "========================"
          echo ""
          COUNT=0
          for spec in sites/*/spec.json; do
            [ -f "$spec" ] || continue
            COUNT=$((COUNT + 1))
            t=$(jq -r '.tag' "$spec")
            n=$(jq -r '.site_name' "$spec")
            s=$(jq -r '.state' "$spec")
            biz=$(jq -r '.business_type // "-"' "$spec")
            url=$(jq -r '.deployed_url // ""' "$spec")
            domain=$(jq -r '.domain // ""' "$spec")
            has_html="no"
            [ -f "sites/$t/dist/index.html" ] && has_html="yes"

            printf "  %-25s %-25s [%s]\n" "$t" "$n" "$s"
            printf "    Type: %-15s  HTML: %-5s" "$biz" "$has_html"
            [ -n "$url" ] && printf "  URL: %s" "$url"
            [ -n "$domain" ] && printf "  Domain: %s" "$domain"
            echo ""
          done
          if [ "$COUNT" -eq 0 ]; then
            echo "  (no sites yet)"
            echo ""
            echo "  Create one: fam-hub site new <tag>"
          else
            echo ""
            echo "  $COUNT site(s) total"
          fi
          echo ""
        else
          [[ "$TAG" == site-* ]] || TAG="site-$TAG"
          if [ -f "sites/$TAG/spec.json" ]; then
            echo "Site: $TAG"
            jq '.' "sites/$TAG/spec.json"
            [ -f "sites/$TAG/state.json" ] && echo "" && echo "State:" && jq '.' "sites/$TAG/state.json"
          else
            echo "No site found for tag: $TAG"
            exit 1
          fi
        fi
        ;;
      deploy)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site deploy <tag> [--prod]"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        shift 3 || true
        "$SCRIPT_DIR/site-deploy" "$TAG" "$@"
        ;;
      export)
        TAG="${3:-}"
        TARGET="${4:-}"
        if [[ -z "$TAG" || -z "$TARGET" ]]; then
          echo "Usage: fam-hub site export <tag> <target-path>"
          echo "  Exports site as a standalone project"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        "$SCRIPT_DIR/site-export" "$TAG" "$TARGET"
        ;;
      import)
        SOURCE="${3:-}"
        TAG="${4:-}"
        if [[ -z "$SOURCE" ]]; then
          echo "Usage: fam-hub site import <source-path> [tag]"
          echo "  Imports existing HTML files into Studio"
          exit 1
        fi
        "$SCRIPT_DIR/site-import" "$SOURCE" "$TAG"
        ;;
      domain)
        TAG="${3:-}"
        DOMAIN="${4:-}"
        if [[ -z "$TAG" || -z "$DOMAIN" ]]; then
          echo "Usage: fam-hub site domain <tag> <domain>"
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        "$SCRIPT_DIR/site-domain" "$TAG" "$DOMAIN"
        ;;
      deal-memo)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub site deal-memo <tag>"
          echo "  Generates a rank-and-rent deal memo for the site."
          exit 1
        fi
        [[ "$TAG" == site-* ]] || TAG="site-$TAG"
        node -e "
const path = require('path');
const fs = require('fs');
const tag = process.argv[1];
const specPath = path.join('$HUB_ROOT', 'sites', tag, 'spec.json');
if (!fs.existsSync(specPath)) { console.error('Site not found: ' + tag); process.exit(1); }
const spec = JSON.parse(fs.readFileSync(specPath,'utf8'));
const brief = spec.design_brief || {};
const cb = spec.client_brief || {};
const revenueModel = cb.revenue_model || spec.revenue_model || 'lead_gen';
const siteName = spec.site_name || tag;
const vertical = spec.business_type || brief.goal || 'local business';
const geography = cb.geography || '[AREA]';
const estimatedLeads = '10-30 qualified leads/month (estimated)';
const proposedFee = '\$500-\$2,000/month (negotiable based on lead volume)';
const date = new Date().toISOString().slice(0,10);

const memo = [
  '# Deal Memo — ' + siteName,
  '**Date:** ' + date,
  '**Revenue model:** ' + revenueModel,
  '',
  '## The Site',
  '- **Name:** ' + siteName,
  '- **Vertical:** ' + vertical,
  '- **Geography:** ' + geography,
  '- **URL:** ' + (spec.deployed_url || '[NOT YET DEPLOYED]'),
  '',
  '## What This Covers',
  '- Professionally built, SEO-optimized website',
  '- Hosted and maintained by FAMtastic Studio',
  '- Lead capture form + call tracking number (you provide number)',
  '- Monthly performance reports',
  '- Ongoing updates and maintenance',
  '',
  '## Estimated Lead Volume',
  estimatedLeads,
  '',
  '## Proposed Terms',
  '- **Monthly fee:** ' + proposedFee,
  '- **Billing:** Monthly, 30-day cancellation notice',
  '- **Phone number:** Client provides (FAMtastic installs tracking)',
  '- **Leads ownership:** Client owns all leads; FAMtastic owns the site',
  '- **If client stops paying:** Phone number removed, site continues',
  '',
  '## Next Steps',
  '1. Agree on monthly fee',
  '2. Client provides phone number for call tracking',
  '3. FAMtastic installs tracking and goes live',
  '4. Monthly invoice via [payment method]',
  '',
  '---',
  '*Generated by FAMtastic Studio — fam-hub site deal-memo ' + tag + '*',
].join('\n');

const outPath = path.join('$HUB_ROOT', 'sites', tag, 'deal-memo.md');
fs.writeFileSync(outPath, memo);
console.log('Deal memo written to: ' + outPath);
console.log('');
console.log(memo);
" "$TAG" 2>&1
        ;;
      *)
        cat <<'SITEHELP'
fam-hub site — Site Factory

Usage:
  fam-hub site new <tag>                    Create site + open chat studio
  fam-hub site chat <tag>                   Open chat studio for existing site
  fam-hub site brainstorm <tag>             Brainstorm ideas from terminal
  fam-hub site preview <tag> [port]         Live preview (default port 3333)
  fam-hub site build <tag> [--template name] Rebuild (batch mode)
  fam-hub site export <tag> <path>            Export as standalone project
  fam-hub site import <path> [tag]           Import existing HTML into Studio
  fam-hub site list [tag]                   Dashboard / site detail
  fam-hub site deploy <tag> [--prod]        Deploy to hosting
  fam-hub site domain <tag> <domain>        DNS setup for custom domain
  fam-hub site deal-memo <tag>              Generate rank-and-rent deal memo

SITEHELP
        ;;
    esac
    ;;

  # --- Idea Capture (from Think-Tank) ---
  idea)
    IDEACMD="${2:-help}"
    shift 2 || true
    case "$IDEACMD" in
      capture)   python3 "$HUB_ROOT/cli/idea/capture.py" "$@" ;;
      triage)    python3 "$HUB_ROOT/cli/idea/triage.py" "$@" ;;
      blueprint) python3 "$HUB_ROOT/cli/idea/blueprint.py" "$@" ;;
      proto|prototype) python3 "$HUB_ROOT/cli/idea/prototype.py" "$@" ;;
      validate)  python3 "$HUB_ROOT/cli/idea/validate.py" "$@" ;;
      learn)     python3 "$HUB_ROOT/cli/idea/learn.py" "$@" ;;
      digest)    python3 "$HUB_ROOT/cli/idea/digest.py" "$@" ;;
      *)
        cat <<'IDEAHELP'
fam-hub idea — Idea Capture & Lifecycle

Usage:
  fam-hub idea capture "<text>" [--tag <t>]  Capture a new idea
  fam-hub idea triage [--list]               List / categorize ideas
  fam-hub idea blueprint <tag>               Create structured plan
  fam-hub idea proto <tag>                   Build prototype
  fam-hub idea validate <tag>                Run validation checks
  fam-hub idea learn <tag> --note "<text>"   Record lesson learned
  fam-hub idea digest [--all]                Summary across all stages

IDEAHELP
        ;;
    esac
    ;;

  # --- Multi-Agent Workflow ---
  agent)
    AGENTCMD="${2:-help}"
    case "$AGENTCMD" in
      run)
        AGENT="${3:-}"; TAG="${4:-}"
        if [[ -z "$AGENT" || -z "$TAG" ]]; then
          echo "Usage: fam-hub agent run <agent> <tag> [history-file] [prompt]"
          echo "  Agents: claude, gemini, codex"
          exit 1
        fi
        shift 4 || true
        "$SCRIPT_DIR/agents" run "$AGENT" "$TAG" "$@"
        ;;
      status)
        TAG="${3:-}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub agent status <tag>"
          exit 1
        fi
        "$SCRIPT_DIR/agents" status "$TAG"
        ;;
      logs)
        TAG="${3:-}"; LOGAGENT="${4:-claude}"
        if [[ -z "$TAG" ]]; then
          echo "Usage: fam-hub agent logs <tag> [agent]"
          exit 1
        fi
        "$SCRIPT_DIR/agents" logs "$TAG" "$LOGAGENT"
        ;;
      help|*)
        echo "Usage: fam-hub agent <command>"
        echo "  run <agent> <tag> [history-file] [prompt]   Run an agent and log to JSONL"
        echo "  status <tag>                                Show status for all agents"
        echo "  logs <tag> [agent]                          Show last 10 conversation exchanges"
        echo ""
        echo "  Agents: claude, gemini, codex"
        ;;
    esac
    ;;

  convo)
    case "$SUBCMD" in
      reconcile) shift 2; "$SCRIPT_DIR/fam-convo-reconcile" "$@" ;;
      *) echo "Usage: fam-hub convo reconcile <tag>" ;;
    esac
    ;;

  ingest)
    TAG="${2:-}"; TYPE="${3:-}"
    if [[ -z "$TAG" || -z "$TYPE" ]]; then
      echo "Usage: fam-hub ingest <tag> {md|json}"
      exit 1
    fi
    shift 3
    "$SCRIPT_DIR/fam-convo-ingest" "$TAG" "$TYPE" "$@"
    ;;

  promote)
    TAG="${2:-}"
    if [[ -z "$TAG" ]]; then
      echo "Usage: fam-hub promote <tag>"
      exit 1
    fi
    shift 2
    "$SCRIPT_DIR/fam-convo-promote" "$TAG" "$@"
    ;;

  capture)
    CAPTURECMD="${2:-help}"
    case "$CAPTURECMD" in
      extract)
        shift 2 || true
        node "$SCRIPT_DIR/capture-insights.js" extract "$@"
        ;;
      help|*)
        cat <<'CAPTUREHELP'
fam-hub capture — Review-only knowledge capture

Usage:
  fam-hub capture extract <source-file> [--out-dir captures/review] [--id capture-id]

Extracts design decisions, breakthroughs, gaps, lessons, and contradictions
into a review packet. It does not write canonical memory files.

CAPTUREHELP
        ;;
    esac
    ;;

  # --- Research ---
  research)
    RESCMD="${2:-help}"
    case "$RESCMD" in
      seed-from-sites)
        node "$SCRIPT_DIR/seed-pinecone" ;;
      sources)
        curl -s http://localhost:3334/api/research/sources | python3 -m json.tool 2>/dev/null || echo "Studio not running" ;;
      effectiveness)
        curl -s http://localhost:3334/api/research/effectiveness | python3 -m json.tool 2>/dev/null || echo "Studio not running" ;;
      query)
        VERTICAL="${3:-general}"; QUESTION="${4:-}"
        if [ -z "$QUESTION" ]; then echo "Usage: fam-hub research query <vertical> \"<question>\""; exit 1; fi
        curl -s -X POST http://localhost:3334/api/research/query \
          -H 'Content-Type: application/json' \
          -d "{\"vertical\":\"$VERTICAL\",\"question\":\"$QUESTION\"}" | python3 -m json.tool 2>/dev/null ;;
      intel-loop|loop|pending-review)
        node "$SCRIPT_DIR/intelligence-loop" ;;
      help|*)
        echo "Usage: fam-hub research <command>"
        echo "  seed-from-sites   Seed Pinecone from existing site specs"
        echo "  sources           List research sources and status"
        echo "  effectiveness     Show effectiveness scores by source"
        echo "  query <v> \"q\"     Query research for a vertical"
        echo "  intel-loop        Run intelligence loop across all sites"
        echo "                    → ~/PENDING-REVIEW.md" ;;
    esac
    ;;

  # --- Plan / Task / Run Intelligence ---
  plan)
    PLANCMD="${2:-list}"
    REGISTRY="$HUB_ROOT/plans/registry.json"

    require_plan_registry() {
      if [ ! -f "$REGISTRY" ]; then
        echo "Plan registry not found: $REGISTRY" >&2
        echo "Create plans/registry.json before using fam-hub plan." >&2
        return 1
      fi
      return 0
    }

    plan_list_standard() {
      jq -r '
        def proof_links:
          (.proof // [])
          | map(if .path then "[\(.label // .path)](\(.path))" else (.label // "-") end)
          | if length == 0 then "-" else join("<br>") end;
        "| Active plan | Status | Current workstream | Next action | Proof | Open blockers |",
        "|---|---|---|---|---|---|",
        (
          .plans[]
          | "| [`\(.id)`](\(.plan_path // "#")) - \(.title) | \(.status_label // .status // "unknown") | \(.current_workstream // "unknown") | \(.next_action // "unknown") | \(proof_links) | \(.open_blockers // "none") |"
        )
      ' "$REGISTRY"
    }

    plan_list_compact() {
      jq -r '
        .plans[]
        | "\(.id)\t\(.status_label // .status // "unknown")\t\(.current_workstream // "unknown")\t\(.next_action // "unknown")"
      ' "$REGISTRY" | awk -F '\t' '{ printf "%-36s %-34s %-48s %s\n", $1, $2, $3, $4 }'
    }

    plan_show_detail() {
      local plan_id="$1"
      jq -r --arg id "$plan_id" '
        def bullets($items):
          if ($items // []) | length == 0 then "- none"
          else ($items // []) | map("- " + .) | join("\n")
          end;
        def proof_bullets:
          if (.proof // []) | length == 0 then "- none"
          else
            (.proof // [])
            | map("- [" + (.label // .path // "proof") + "](" + (.path // "#") + ")")
            | join("\n")
          end;
        .plans[] | select(.id == $id) |
          "# " + .id + " - " + .title + "\n\n" +
          "| Field | Value |\n|---|---|\n" +
          "| Status | " + (.status_label // .status // "unknown") + " |\n" +
          "| Group | " + (.group // "unknown") + " |\n" +
          "| Source plan | " + (.plan_path // "unknown") + " |\n" +
          "| Originator | " + (.originator // "unknown") + " |\n" +
          "| Origin surface | " + (.origin_surface // "unknown") + " |\n" +
          "| Current runner | " + (.current_runner // "unknown") + " |\n" +
          "| Runner surface | " + (.runner_surface // "unknown") + " |\n" +
          "| Run target | " + (.run_target // "unknown") + " |\n" +
          "| Handling | " + (.handling // "unknown") + " |\n" +
          "| Current workstream | " + (.current_workstream // "unknown") + " |\n" +
          "| Next action | " + (.next_action // "unknown") + " |\n" +
          "| Open blockers | " + (.open_blockers // "none") + " |\n\n" +
          "## Proof\n\n" + proof_bullets + "\n\n" +
          "## Tasks\n\n" + bullets(.tasks) + "\n\n" +
          "## Assumptions\n\n" + bullets(.assumptions)
      ' "$REGISTRY"
    }

    case "$PLANCMD" in
      list|status)
        require_plan_registry || exit 1
        FORMAT="standard"
        if [ "${3:-}" = "--compact" ]; then
          FORMAT="compact"
        elif [ "${3:-}" = "--json" ] || [ "${3:-}" = "--format=json" ]; then
          FORMAT="json"
        elif [ "${3:-}" = "--standard" ]; then
          FORMAT="standard"
        fi
        case "$FORMAT" in
          compact) plan_list_compact ;;
          json) jq '.' "$REGISTRY" ;;
          standard) plan_list_standard ;;
        esac
        ;;
      show)
        require_plan_registry || exit 1
        PLAN_ID="${3:-}"
        if [ -z "$PLAN_ID" ]; then
          echo "Usage: fam-hub plan show <plan-id>" >&2
          exit 1
        fi
        if ! jq -e --arg id "$PLAN_ID" '.plans[] | select(.id == $id)' "$REGISTRY" >/dev/null; then
          echo "Plan not found: $PLAN_ID" >&2
          echo "Run: fam-hub plan list --compact" >&2
          exit 1
        fi
        plan_show_detail "$PLAN_ID"
        ;;
      review)
        require_plan_registry || exit 1
        TASK_LEDGER="$HUB_ROOT/tasks/tasks.jsonl"
        RUN_LEDGER="$HUB_ROOT/runs/runs.jsonl"
        PROOF_LEDGER="$HUB_ROOT/proofs/proof-ledger.jsonl"
        plan_count=$(jq '.plans | length' "$REGISTRY")
        active_count=$(jq '[.plans[] | select(.status == "active")] | length' "$REGISTRY")
        parent_count=$(jq '.active_parent_ids | length' "$REGISTRY")
        absorbed_count=$(jq '.absorbed_records | length' "$REGISTRY")
        task_count=0
        run_count=0
        proof_count=0
        [ -f "$TASK_LEDGER" ] && task_count=$(grep -c '[^[:space:]]' "$TASK_LEDGER" || true)
        [ -f "$RUN_LEDGER" ] && run_count=$(grep -c '[^[:space:]]' "$RUN_LEDGER" || true)
        [ -f "$PROOF_LEDGER" ] && proof_count=$(grep -c '[^[:space:]]' "$PROOF_LEDGER" || true)

        echo "Plan Registry Review"
        echo "===================="
        echo ""
        printf "Registry:          %s\n" "$REGISTRY"
        printf "Plans shown:       %s\n" "$plan_count"
        printf "Active parents:    %s / expected %s\n" "$active_count" "$parent_count"
        printf "Absorbed records:  %s\n" "$absorbed_count"
        printf "Task records:      %s\n" "$task_count"
        printf "Run records:       %s\n" "$run_count"
        printf "Proof records:     %s\n" "$proof_count"
        echo ""
        echo "Active parent IDs:"
        jq -r '.active_parent_ids[] | "  - " + .' "$REGISTRY"
        echo ""
        echo "Warnings:"
        warn=0
        if [ "$plan_count" -ne "$parent_count" ]; then
          echo "  - .plans length does not match active_parent_ids length"
          warn=1
        fi
        if [ "$active_count" -ne "$parent_count" ]; then
          echo "  - active plan count does not match active_parent_ids length"
          warn=1
        fi
        if [ "$task_count" -eq 0 ]; then
          echo "  - task ledger is empty"
          warn=1
        fi
        if [ "$run_count" -eq 0 ]; then
          echo "  - run ledger is empty"
          warn=1
        fi
        if [ "$proof_count" -eq 0 ]; then
          echo "  - proof ledger is empty"
          warn=1
        fi
        if [ "$warn" -eq 0 ]; then
          echo "  none"
        fi
        ;;
      help|*)
        cat <<'PLANHELP'
fam-hub plan — Plan / task / run intelligence

Usage:
  fam-hub plan list                 Show the standard six-field plan list
  fam-hub plan list --compact       Show one-line compact plan statuses
  fam-hub plan list --json          Print raw plans/registry.json
  fam-hub plan status               Alias for plan list
  fam-hub plan show <plan-id>       Show detail for one plan
  fam-hub plan review               Review registry/ledger health

PLANHELP
        ;;
    esac
    ;;

  task)
    TASKCMD="${2:-list}"
    TASK_LEDGER="$HUB_ROOT/tasks/tasks.jsonl"
    case "$TASKCMD" in
      list|status)
        PLAN_FILTER=""
        if [ "${3:-}" = "--plan" ]; then
          PLAN_FILTER="${4:-}"
        fi
        if [ ! -f "$TASK_LEDGER" ] || ! grep -q '[^[:space:]]' "$TASK_LEDGER"; then
          echo "No task records yet."
          echo "Seed source: plans/registry.json"
          echo "Next: promote plan tasks into tasks/tasks.jsonl with plan_id, task_id, runner, status, proof_required."
          exit 0
        fi
        if [ -n "$PLAN_FILTER" ]; then
          echo "| Task | Status | Title | Runner | Next action |"
          echo "|---|---|---|---|---|"
          jq -r --arg plan "$PLAN_FILTER" '
            select(.plan_id == $plan)
            | "| `\(.task_id // .id)` | \(.status // "unknown") | \(.title // .summary // "untitled") | \(.runner // "unassigned") | \(.next_action // "-") |"
          ' "$TASK_LEDGER"
        else
          echo "| Task | Plan | Status | Runner | Next action |"
          echo "|---|---|---|---|---|"
          jq -r '
            "| `\(.task_id // .id)` | \(.plan_id // "unknown") | \(.status // "unknown") | \(.runner // "unassigned") | \(.next_action // "-") |"
          ' "$TASK_LEDGER"
        fi
        ;;
      promote)
        REGISTRY="$HUB_ROOT/plans/registry.json"
        MODE="dry-run"
        PLAN_FILTER=""
        for arg in "${@:3}"; do
          case "$arg" in
            --apply) MODE="apply" ;;
            --dry-run) MODE="dry-run" ;;
            --plan=*) PLAN_FILTER="${arg#--plan=}" ;;
          esac
        done
        if [ ! -f "$REGISTRY" ]; then
          echo "Plan registry not found: $REGISTRY" >&2
          exit 1
        fi
        mkdir -p "$(dirname "$TASK_LEDGER")"
        tmp_promote=$(mktemp)
        jq -c --arg plan "$PLAN_FILTER" '
          .plans[]
          | select($plan == "" or .id == $plan)
          | . as $p
          | ($p.tasks // [])
          | to_entries[]
          | {
              task_id: ("task-" + $p.id + "-" + ((.key + 1) | tostring)),
              plan_id: $p.id,
              priority: "P2",
              status: "ready",
              title: .value,
              runner: ($p.current_runner // "unassigned"),
              next_action: .value,
              acceptance: "Promoted from plans/registry.json task array.",
              proof_required: [($p.plan_path // "plans/registry.json")],
              source: "plans/registry.json",
              auto_approved: true
            }
        ' "$REGISTRY" > "$tmp_promote"
        if [ "$MODE" = "dry-run" ]; then
          echo "Dry run: would promote these tasks if not already present:"
          jq -r '"  - \(.task_id) [\(.plan_id)] \(.title)"' "$tmp_promote"
          rm -f "$tmp_promote"
          exit 0
        fi
        touch "$TASK_LEDGER"
        promoted=0
        while IFS= read -r record; do
          [ -n "$record" ] || continue
          task_id=$(printf '%s\n' "$record" | jq -r '.task_id')
          if grep -q "\"task_id\":\"$task_id\"" "$TASK_LEDGER"; then
            continue
          fi
          printf '%s\n' "$record" >> "$TASK_LEDGER"
          promoted=$((promoted + 1))
        done < "$tmp_promote"
        rm -f "$tmp_promote"
        echo "Promoted $promoted task(s)."
        ;;
      help|*)
        cat <<'TASKHELP'
fam-hub task — Task ledger status

Usage:
  fam-hub task list                 Show all task records
  fam-hub task list --plan <id>     Show task records for one plan
  fam-hub task promote --dry-run    Preview task promotion from registry
  fam-hub task promote --apply      Append missing promoted task records

TASKHELP
        ;;
    esac
    ;;

  run)
    RUNCMD="${2:-status}"
    RUN_LEDGER="$HUB_ROOT/runs/runs.jsonl"
    case "$RUNCMD" in
      status|list)
        PLAN_FILTER=""
        if [ "${3:-}" = "--plan" ]; then
          PLAN_FILTER="${4:-}"
        fi
        if [ ! -f "$RUN_LEDGER" ] || ! grep -q '[^[:space:]]' "$RUN_LEDGER"; then
          echo "No run records yet."
          echo "Next: create runs/runs.jsonl entries when a plan is started with a target like complete, 50%, timebox, or until_blocked."
          exit 0
        fi
        if [ -n "$PLAN_FILTER" ]; then
          echo "| Run | Status | Target | Runner | Current step | Report back |"
          echo "|---|---|---|---|---|---|"
          jq -r --arg plan "$PLAN_FILTER" '
            select(.plan_id == $plan)
            | "| `\(.run_id // .id)` | \(.status // "unknown") | \(.target // "unknown") | \(.runner // "unassigned") | \(.current_step // "-") | \(.report_back // "-") |"
          ' "$RUN_LEDGER"
        else
          echo "| Run | Plan | Status | Target | Runner | Current step | Report back |"
          echo "|---|---|---|---|---|---|---|"
          jq -r '
            "| `\(.run_id // .id)` | \(.plan_id // "unknown") | \(.status // "unknown") | \(.target // "unknown") | \(.runner // "unassigned") | \(.current_step // "-") | \(.report_back // "-") |"
          ' "$RUN_LEDGER"
        fi
        ;;
      start)
        PLAN_ID="${3:-}"
        TARGET="${4:-complete}"
        MODE="apply"
        if [ "${5:-}" = "--dry-run" ] || [ "${3:-}" = "--dry-run" ]; then
          MODE="dry-run"
        fi
        if [ -z "$PLAN_ID" ] || [ "$PLAN_ID" = "--dry-run" ]; then
          echo "Usage: fam-hub run start <plan-id> [target] [--dry-run]" >&2
          exit 1
        fi
        REGISTRY="$HUB_ROOT/plans/registry.json"
        if [ ! -f "$REGISTRY" ]; then
          echo "Plan registry not found: $REGISTRY" >&2
          exit 1
        fi
        if ! jq -e --arg id "$PLAN_ID" '.plans[] | select(.id == $id)' "$REGISTRY" >/dev/null; then
          echo "Plan not found: $PLAN_ID" >&2
          exit 1
        fi
        ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        safe_ts=$(date -u +"%Y%m%d%H%M%S")
        run_id="run-$safe_ts-$PLAN_ID"
        record=$(jq -cn \
          --arg run_id "$run_id" \
          --arg plan_id "$PLAN_ID" \
          --arg target "$TARGET" \
          --arg started_at "$ts" \
          '{
            run_id: $run_id,
            plan_id: $plan_id,
            status: "active",
            target: $target,
            runner: "Codex",
            started_at: $started_at,
            current_step: "started",
            report_back: "Report progress at committed checkpoints.",
            background_allowed: true,
            auto_approved: true,
            source: "fam-hub run start"
          }')
        if [ "$MODE" = "dry-run" ]; then
          printf '%s\n' "$record" | jq '.'
          exit 0
        fi
        mkdir -p "$(dirname "$RUN_LEDGER")"
        printf '%s\n' "$record" >> "$RUN_LEDGER"
        echo "Started run: $run_id"
        ;;
      help|*)
        cat <<'RUNHELP'
fam-hub run — Active run ledger status

Usage:
  fam-hub run status                Show all run records
  fam-hub run status --plan <id>    Show runs for one plan
  fam-hub run start <plan-id> [target] [--dry-run]

RUNHELP
        ;;
    esac
    ;;

  # --- Studio Tier patches ---
  studio)
    STUDIOCMD="${2:-help}"
    case "$STUDIOCMD" in
      patches)
        ACTION="${3:-list}"
        PATCH_ID="${4:-}"
        PENDING_DIR="$HUB_ROOT/.studio-patches/pending"
        APPLIED_DIR="$HUB_ROOT/.studio-patches/applied"
        REJECTED_DIR="$HUB_ROOT/.studio-patches/rejected"

        # Strict patch-id regex: ISO-timestamp-shape + 6-hex suffix.
        # No path separators, no '..', no shell metacharacters.
        validate_patch_id() {
          local id="$1"
          if [[ ! "$id" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}-[0-9]{3}Z-[0-9a-f]{6}$ ]]; then
            echo "Error: invalid patch id format: $id" >&2
            echo "       expected ISO-timestamp + 6-hex suffix (e.g. 2026-04-30T19-13-55-073Z-8669e6)" >&2
            return 1
          fi
          return 0
        }

        # Strip ANSI escapes and other terminal control bytes from a string,
        # so a patch description can't smuggle escape sequences into the
        # operator's terminal.
        sanitize_terminal() {
          # Filter ESC [ ... letter sequences plus bare control bytes (except \t \n).
          tr -d '\001-\010\013\014\016-\037\177' | sed -E $'s/\x1b\\[[0-9;?]*[A-Za-z]//g'
        }

        case "$ACTION" in
          list)
            if [ ! -d "$PENDING_DIR" ] || [ -z "$(ls -A "$PENDING_DIR" 2>/dev/null)" ]; then
              echo "No pending patches."
              exit 0
            fi
            echo "Pending patches:"
            for f in "$PENDING_DIR"/*.json; do
              [ -f "$f" ] || continue
              id=$(basename "$f" .json)
              target=$(jq -r '.path' "$f" | sanitize_terminal)
              desc=$(jq -r '.description' "$f" | sanitize_terminal)
              flagged=$(jq -r '.flagged_secret // false' "$f")
              policy=$(jq -r '.policy_at_propose // "?"' "$f")
              if [ "$flagged" = "true" ]; then
                printf "  ⚠  %s  →  %s  [%s]\n" "$id" "$target" "$policy"
                printf "     %s\n" "$desc"
                printf "     ⚠ TOUCHES SECRET-BEARING FILE\n"
              else
                printf "     %s  →  %s  [%s]\n" "$id" "$target" "$policy"
                printf "     %s\n" "$desc"
              fi
            done
            ;;
          show)
            if [ -z "$PATCH_ID" ]; then
              echo "Usage: fam-hub studio patches show <id>" >&2
              exit 1
            fi
            validate_patch_id "$PATCH_ID" || exit 1
            f="$PENDING_DIR/$PATCH_ID.json"
            if [ ! -f "$f" ]; then
              echo "Patch not found in pending: $PATCH_ID" >&2
              exit 1
            fi
            target=$(jq -r '.path' "$f" | sanitize_terminal)
            desc=$(jq -r '.description' "$f" | sanitize_terminal)
            flagged=$(jq -r '.flagged_secret // false' "$f")
            policy=$(jq -r '.policy_at_propose // "?"' "$f")
            old_str=$(jq -r '.old_str' "$f")
            new_str=$(jq -r '.new_str' "$f")
            echo "Patch:       $PATCH_ID"
            echo "Target:      $target"
            echo "Policy:      $policy"
            echo "Description: $desc"
            if [ "$flagged" = "true" ]; then
              echo "⚠ Flagged:    touches a secret-bearing file (override was acknowledged at proposal)"
            fi
            echo ""
            echo "--- old"
            printf "%s\n" "$old_str" | sanitize_terminal
            echo "+++ new"
            printf "%s\n" "$new_str" | sanitize_terminal
            ;;
          apply)
            if [ -z "$PATCH_ID" ]; then
              echo "Usage: fam-hub studio patches apply <id>" >&2
              exit 1
            fi
            validate_patch_id "$PATCH_ID" || exit 1
            f="$PENDING_DIR/$PATCH_ID.json"
            if [ ! -f "$f" ]; then
              echo "Patch not found in pending: $PATCH_ID" >&2
              exit 1
            fi

            # Re-validate via the Node helper. It re-resolves path against the
            # current inventory and re-checks old_str uniqueness.
            VALIDATE_OUT=$(HUB_ROOT="$HUB_ROOT" node "$HUB_ROOT/scripts/lib/studio-tier-validate.js" "$f")
            VALIDATE_RC=$?
            if [ $VALIDATE_RC -ne 0 ]; then
              echo "Apply refused — validation failed:" >&2
              echo "$VALIDATE_OUT" | jq -r '.error' >&2
              policy_change=$(echo "$VALIDATE_OUT" | jq -r '"\(.current_policy)|\(.policy_at_propose)"')
              if [ -n "$policy_change" ] && [ "$policy_change" != "null|null" ]; then
                echo "Policy at propose: $(echo "$VALIDATE_OUT" | jq -r '.policy_at_propose // "n/a"')" >&2
                echo "Policy now:        $(echo "$VALIDATE_OUT" | jq -r '.current_policy // "n/a"')" >&2
              fi
              exit 1
            fi

            FLAGGED=$(echo "$VALIDATE_OUT" | jq -r '.flagged_secret')
            if [ "$FLAGGED" = "true" ]; then
              TARGET=$(jq -r '.path' "$f" | sanitize_terminal)
              echo "⚠  This patch modifies a flagged secret-bearing file: $TARGET" >&2
              echo "   The patch was proposed with explicit acknowledgment." >&2
              echo "   Proceeding with apply." >&2
            fi

            ABS=$(echo "$VALIDATE_OUT" | jq -r '.abs')

            # Use Python to perform the literal replacement — handles multiline
            # strings safely without shell quoting hazards.
            python3 - "$f" "$ABS" <<'PYEOF'
import json, sys, pathlib
patch  = json.load(open(sys.argv[1]))
target = pathlib.Path(sys.argv[2])
content = target.read_text()
count   = content.count(patch['old_str'])
if count == 0:
    print(f"ERROR: old_str no longer in file (file changed since validation)", file=sys.stderr)
    sys.exit(1)
if count > 1:
    print(f"ERROR: old_str matches {count} times — ambiguous", file=sys.stderr)
    sys.exit(1)
target.write_text(content.replace(patch['old_str'], patch['new_str']))
print(f"Applied to {target}")
PYEOF
            APPLY_RC=$?
            if [ $APPLY_RC -ne 0 ]; then
              echo "Apply failed — patch left in pending." >&2
              exit 1
            fi

            mkdir -p "$APPLIED_DIR"
            mv "$f" "$APPLIED_DIR/"
            echo "Patch $PATCH_ID applied and archived to $APPLIED_DIR"

            # Notify Studio so it can broadcast patch-applied to the proposing
            # convId and queue a verification reminder. Best-effort — silence
            # curl errors so a stopped Studio doesn't fail the apply.
            STUDIO_PORT="${STUDIO_PORT:-3334}"
            APPLIED_BODY=$(jq -n --arg id "$PATCH_ID" --arg status "applied" '{id:$id, status:$status}')
            curl -s -m 3 -X POST "http://localhost:$STUDIO_PORT/api/studio-patches/applied" \
              -H "Content-Type: application/json" \
              -H "Origin: http://localhost:$STUDIO_PORT" \
              -d "$APPLIED_BODY" >/dev/null 2>&1 \
              && echo "Notified Studio of patch apply." \
              || echo "Note: Studio notify skipped (Studio not running on :$STUDIO_PORT)."
            ;;
          reject)
            if [ -z "$PATCH_ID" ]; then
              echo "Usage: fam-hub studio patches reject <id>" >&2
              exit 1
            fi
            validate_patch_id "$PATCH_ID" || exit 1
            f="$PENDING_DIR/$PATCH_ID.json"
            if [ ! -f "$f" ]; then
              echo "Patch not found in pending: $PATCH_ID" >&2
              exit 1
            fi
            mkdir -p "$REJECTED_DIR"
            mv "$f" "$REJECTED_DIR/"
            echo "Patch $PATCH_ID rejected and archived to $REJECTED_DIR"
            ;;
          *)
            cat <<'PHELP'
fam-hub studio patches — Studio Tier patch review

Usage:
  fam-hub studio patches list                 List pending patches
  fam-hub studio patches show <id>            Show patch metadata + diff
  fam-hub studio patches apply <id>           Re-validate and apply a pending patch
  fam-hub studio patches reject <id>          Move patch to rejected/

PHELP
            ;;
        esac
        ;;
      *)
        cat <<'STUDIOHELP'
fam-hub studio — Studio Tier mode

Usage:
  fam-hub studio patches [list|show|apply|reject] [id]
                                              Review and apply patches that
                                              Shay-Shay proposed via the
                                              Studio Tier tools.

STUDIOHELP
        ;;
    esac
    ;;

  report)
    REPORTCMD="${2:-style}"
    REPORT_PREFS="$HUB_ROOT/config/reporting-preferences.json"
    case "$REPORTCMD" in
      style|density)
        NEW_DENSITY="${3:-}"
        if [ ! -f "$REPORT_PREFS" ]; then
          echo "Reporting preferences not found: $REPORT_PREFS" >&2
          exit 1
        fi
        if [ -z "$NEW_DENSITY" ]; then
          echo "Reporting density: $(jq -r '.current_density // .default_density // "compact"' "$REPORT_PREFS")"
          echo "Config: config/reporting-preferences.json"
          echo ""
          jq -r '.densities | to_entries[] | "  - \(.key): \(.value.description)"' "$REPORT_PREFS"
          exit 0
        fi
        case "$NEW_DENSITY" in
          compact|standard|detail) ;;
          *)
            echo "Invalid reporting density: $NEW_DENSITY" >&2
            echo "Use: compact, standard, or detail" >&2
            exit 1
            ;;
        esac
        tmp_report_prefs="$(mktemp)"
        jq --arg density "$NEW_DENSITY" '.current_density = $density' "$REPORT_PREFS" > "$tmp_report_prefs"
        mv "$tmp_report_prefs" "$REPORT_PREFS"
        echo "Reporting density set to: $NEW_DENSITY"
        ;;
      help|*)
        cat <<'REPORTHELP'
fam-hub report — Reporting preferences

Usage:
  fam-hub report style              Show current response/reporting density
  fam-hub report style compact      Short completion/status responses
  fam-hub report style standard     Balanced summaries
  fam-hub report style detail       Full audit-trail responses

REPORTHELP
        ;;
    esac
    ;;

  platform)
    PLATFORMCMD="${2:-help}"
    case "$PLATFORMCMD" in
      bootstrap-services)
        shift 2 || true
        "$HUB_ROOT/platform/famtastic-platform" studio bootstrap-services "$@"
        ;;
      configure-resend)
        shift 2 || true
        "$HUB_ROOT/platform/famtastic-platform" studio configure-resend "$@"
        ;;
      send-test-email)
        shift 2 || true
        "$HUB_ROOT/platform/famtastic-platform" studio send-test-email "$@"
        ;;
      provision-site)
        SITE_ARG="${3:-}"
        if [ -z "$SITE_ARG" ]; then
          echo "Usage: fam-hub platform provision-site <site> [--check] [--proof]" >&2
          exit 1
        fi
        shift 2 || true
        "$HUB_ROOT/platform/famtastic-platform" studio provision-site "$@"
        ;;
      list|capabilities)
        "$HUB_ROOT/platform/famtastic-platform" list
        ;;
      vault)
        shift 2 || true
        "$HUB_ROOT/platform/famtastic-platform" vault "$@"
        ;;
      help|*)
        cat <<'PLATFORMHELP'
fam-hub platform — Site Studio service capabilities

Usage:
  fam-hub platform bootstrap-services [--check]
      Check or bootstrap Studio-owned Netlify, Resend, DB, DNS, cPanel, and SSH auth.

  fam-hub platform configure-resend [--check]
      Configure Site Studio's own Resend sender for notifications.

  fam-hub platform send-test-email [recipient]
      Send a Site Studio notification test email through Resend.

  fam-hub platform provision-site <site> [--check] [--proof]
      Verify a generated site consumes Studio-owned services instead of owning providers.

  fam-hub platform vault <read|write|list|remove> ...
      Access the platform vault through the unified CLI.

PLATFORMHELP
        ;;
    esac
    ;;

  # --- Admin ---
  admin)
    ADMINCMD="${2:-help}"
    case "$ADMINCMD" in
      doctor)
        echo "FAMtastic Health Check"
        echo "======================"
        echo ""
        printf "  %-25s " "claude CLI"
        command -v claude >/dev/null 2>&1 && echo "[OK]" || echo "[MISSING]"
        printf "  %-25s " "node"
        command -v node >/dev/null 2>&1 && echo "[OK] $(node --version)" || echo "[MISSING]"
        printf "  %-25s " "python3"
        command -v python3 >/dev/null 2>&1 && echo "[OK] $(python3 --version 2>&1)" || echo "[MISSING]"
        printf "  %-25s " "jq"
        command -v jq >/dev/null 2>&1 && echo "[OK]" || echo "[MISSING]"
        printf "  %-25s " "netlify"
        command -v netlify >/dev/null 2>&1 && echo "[OK]" || echo "[MISSING]"
        printf "  %-25s " "site-studio deps"
        [ -d "site-studio/node_modules" ] && echo "[OK]" || echo "[MISSING] run: cd site-studio && npm install"
        printf "  %-25s " "sites directory"
        SITE_COUNT=$(find sites -maxdepth 2 -name spec.json 2>/dev/null | wc -l | tr -d ' ')
        echo "[$SITE_COUNT sites]"
        echo ""
        ;;
      verify)
        echo "Verifying repo structure..."
        ERRORS=0
        for f in scripts/fam-hub scripts/orchestrator-site scripts/claude-cli scripts/site-preview scripts/site-deploy; do
          if [ -x "$f" ]; then
            printf "  [+] %s\n" "$f"
          else
            printf "  [x] %s (missing or not executable)\n" "$f"
            ERRORS=$((ERRORS + 1))
          fi
        done
        for d in sites config/site-templates site-studio/public adapters schemas; do
          if [ -d "$d" ]; then
            printf "  [+] %s/\n" "$d"
          else
            printf "  [x] %s/ (missing)\n" "$d"
            ERRORS=$((ERRORS + 1))
          fi
        done
        echo ""
        [ "$ERRORS" -eq 0 ] && echo "All checks passed." || echo "$ERRORS issue(s) found."
        ;;
      check-tools)
        echo "=== FAMtastic Tool Check ==="
        echo "Checks that required CLI tools are installed and on PATH."
        echo "Does not verify Studio starts correctly — run fam-hub site start for that."
        echo ""
        for tool in node npm python3 claude netlify; do
          if command -v "$tool" &>/dev/null; then
            echo "  ✅ $tool: $(command -v $tool)"
          else
            echo "  ✗ $tool: NOT FOUND"
          fi
        done
        ;;
      verify-quickstart)
        echo "WARNING: verify-quickstart is deprecated, use: fam-hub admin check-tools" >&2
        exec "$0" admin check-tools "$@"
        ;;
      *)
        cat <<'ADMINHELP'
fam-hub admin — Health & Diagnostics

Usage:
  fam-hub admin doctor      Check tool dependencies
  fam-hub admin verify      Verify repo structure
  fam-hub admin check-tools Check required CLI tools are installed and on PATH.
                             (verify-quickstart is a deprecated alias for this)

ADMINHELP
        ;;
    esac
    ;;

  *)
    cat <<'EOF'
fam-hub — FAMtastic CLI

Site Factory:
  fam-hub site new <tag>            Create site + open chat studio
  fam-hub site brainstorm <tag>     Brainstorm ideas from terminal
  fam-hub site build <tag>          Rebuild site (batch mode)
  fam-hub site export <tag> <path>  Export as standalone project
  fam-hub site import <path> [tag]  Import existing HTML into Studio
  fam-hub site list                 Dashboard of all sites
  fam-hub site deploy <tag>         Deploy to hosting
  fam-hub site domain <tag> <dom>   DNS setup guide

Idea Capture:
  fam-hub idea capture "<text>"     Capture a new idea
  fam-hub idea digest [--all]       Summary across all stages
  fam-hub idea validate <tag>       Run validation checks

Multi-Agent Workflow:
  fam-hub agent run <agent> <tag>   Run agent on a tag
  fam-hub convo reconcile <tag>     Reconcile multi-agent conversation
  fam-hub ingest <tag> {md|json}    Ingest content
  fam-hub capture extract <file>     Produce review-only knowledge packet
  fam-hub report style               Show/set response reporting density
  fam-hub platform bootstrap-services Check Studio-owned service auth
  fam-hub platform configure-resend   Configure Studio notification email
  fam-hub platform send-test-email    Send Studio notification test
  fam-hub platform provision-site <s> Check generated-site service wiring

Admin:
  fam-hub admin doctor              Check dependencies
  fam-hub admin verify              Verify repo structure

Run 'fam-hub <command>' for detailed help on each command.

EOF
    ;;
esac
