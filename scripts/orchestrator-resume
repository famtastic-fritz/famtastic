#!/usr/bin/env bash
set -euo pipefail
TAG="${1:-job-test}"
ROOT="$HOME/famtastic"
IN="$ROOT/inputs"
OUT="$ROOT/outputs/resumes/$TAG"
SRC="${XDG_DATA_HOME:-$HOME/.local/share}/famtastic/agent-hub/sources/resume"
mkdir -p "$OUT" "$SRC"

# Step 1: Claude (stub)
REQ="$OUT/requirements.json"
echo '{"requirements":["Degree in CS","5+ years Drupal","React knowledge"]}' > "$REQ"

# Step 2: Codex (stub)
cp "$IN/resume.md" "$OUT/resume-tailored.md"
echo -e "\n<!-- Tailored for $TAG: Added emphasis on Drupal + React -->" >> "$OUT/resume-tailored.md"

# Step 3: Gemini (stub, optional)
# (no-op for now)

# Log JSONL
TS="$(date -u +%FT%TZ)"
ID=$(uuidgen)
jq -c -n --arg id "$ID" --arg at "$TS" --arg tag "$TAG" --arg r "resume" --arg out "$OUT/resume-tailored.md" \
  '{id:$id,at:$at,agent:$r,tag:$tag,messages:[{role:"system",content:"resume orchestration"},{role:"assistant",content:("output at " + $out)}]}' \
  >> "$SRC/$TAG.jsonl"

echo "[resume-orchestrator] Tailored resume at $OUT/resume-tailored.md"