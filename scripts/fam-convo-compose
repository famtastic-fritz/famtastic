#!/usr/bin/env bash
set -euo pipefail
. "$(dirname "$0")/lib/hub-common"

tag="${1:?usage: cj-compose-convo <tag>}"

# Gather from all known agents (extendable via catalog later)
tmp_file=$(mktemp)
for agent in claude gemini codex; do
  cat_sources "$agent" "$tag" >> "$tmp_file" || true
done

if [ ! -s "$tmp_file" ]; then
  echo "Compose failed, no sources found for tag: $tag" >&2
  rm "$tmp_file"
  exit 1
fi

# Create canonical JSON
canon_json=$(jq -sc '{tag:"'"$tag"'",policy:"latest",messages:[.[]|.messages? // []]|flatten}' "$tmp_file")
echo "$canon_json"

echo "---"

# Create manifest JSON
hash=$(echo "$canon_json" | json_hash)
now=$(utc_now)
counts=$(echo "$canon_json" | jq '[.messages[].role]|group_by(.)|map({(.[0]):length})|add')
manifest_json=$(cat <<JSON
{
  "tag":"$tag",
  "policy":"latest",
  "agents":["claude","gemini","codex"],
  "source_hashes":{},
  "message_counts": $counts,
  "hash":"sha256:$hash",
  "updated_at":"$now"
}
JSON
)
echo "$manifest_json"

echo "---"

# Create summary MD
ts=$(date -u +"%Y%m%d-%H%M")
summary_md=$(cat <<MD
# $tag — Summary
Updated: $(date -u +"%Y-%m-%d %H:%MZ")
Policy: latest
Agents: claude, gemini, codex
Counts: $(echo "$counts" | jq -r '"user=\(.user//0) assistant=\(.assistant//0) system=\(.system//0)"')
Hash: sha256:$hash

## What changed since last compose
- …

## Highlights
- …

## TODO / Follow-ups
- …

## Provenance
- Reconciled: $now
MD
)
echo "$summary_md"

rm "$tmp_file"
