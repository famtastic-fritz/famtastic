#!/usr/bin/env bash
set -euo pipefail
. "$(dirname "$0")/_cj_common.sh"


cmd="${1:-help}"; shift || true


case "$cmd" in
  setup)
    echo "[agents] Ensuring jq OR node is available…"
    if ! command -v jq >/dev/null 2>&1 && ! command -v node >/dev/null 2>&1; then
      if command -v brew >/dev/null 2>&1; then
        echo "[agents] Installing jq via brew (requires consent)…"
        brew install jq || true
      else
        echo "[agents] No jq/node found. Install one manually (brew install jq OR install node)."
      fi
    fi
    mkdir -p "$CJ_SOURCES_DIR"/{claude,gemini,codex} "$CJ_LOCK_DIR" "$CJ_CONFIG_DIR"
    [ -d "$HOME/.codex/sources" ] && echo "[agents] Note: legacy sources exist at ~/.codex/sources (still read as fallback)."
    echo "[agents] Setup done. Sources: $CJ_SOURCES_DIR  Locks: $CJ_LOCK_DIR  Config: $CJ_CONFIG_DIR"
    ;;
  secrets)
    sub="${1:-}"; prov="${2:-}"; shift || true
    case "$sub" in
      set)
        [ -z "${prov:-}" ] && { echo "usage: ./scripts/agents secrets set <provider>"; exit 2; }
        os="$(uname -s 2>/dev/null || echo unknown)"
        if [ "$os" = "Darwin" ]; then
          printf "Enter secret for %s: " "$prov"; stty -echo; read -r sec; stty echo; echo
          security add-generic-password -a "$USER" -s "agents:$prov" -w "$sec" -U >/dev/null 2>&1 || true
          echo "[agents] stored in Keychain as agents:$prov"
        else
          echo "[agents] implement Linux secret-tool fallback as needed (service=agents provider=$prov)"
        fi
        ;;
      list)
        os="$(uname -s 2>/dev/null || echo unknown)"
        if [ "$os" = "Darwin" ]; then
          echo "[agents] providers in Keychain (macOS):"
          security find-generic-password -a "$USER" -g 2>&1 | grep -E "svce|acct" | grep -i '^ *"svce"<blob>="agents:' || echo "(none)"
        else
          echo "[agents] list not implemented for this OS"
        fi
        ;;
      *) echo "usage: ./scripts/agents secrets {set|list} <provider?>"; exit 2;;
    esac
    ;;
  update)
    git -C "$(pwd)" fetch --all --prune || true
    git -C "$(pwd)" pull --rebase || true
    echo "[agents] repo updated."
    ;;
  help|*)
    cat <<EOF
Usage: ./scripts/agents {setup|secrets|update}
  setup               Ensure jq/node and create XDG dirs
  secrets set <prov>  Store provider secret as Keychain 'agents:<prov>'
  secrets list        List agents:* items (macOS)
  update              git pull this repo
EOF
    ;;
cesac
