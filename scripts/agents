#!/usr/bin/env bash
set -euo pipefail
ROOT="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"
cmd="${1:-help}"; shift || true

has(){ command -v "$1" >/dev/null 2>&1; }
safe_yaml(){ python3 - <<PY
import sys, yaml
print(yaml.safe_dump(yaml.safe_load(sys.stdin.read()) or {}, sort_keys=False))
PY
}

ensure_sops(){ [ -n "${SOPS_AGE_KEY_FILE:-}" ] || { echo "SOPS_AGE_KEY_FILE not set"; exit 1; }; }

action_repo_secrets(){
  ensure_sops
  tmp="$(mktemp)"
  if [ -f secrets/agents.enc.yaml ]; then
    sops -d secrets/agents.enc.yaml > "$tmp"
  else
    printf '---\n' > "$tmp"
  fi
  # merge env keys if present
  python3 - "$tmp" <<'PY'
import os, sys, yaml
p=sys.argv[1]
with open(p,'r') as f:
    data=yaml.safe_load(f) or {}
for k in ("ANTHROPIC_API_KEY","GEMINI_API_KEY"):
    v=os.environ.get(k)
    if v:
        data[k]=v
with open(p,'w') as f:
    yaml.safe_dump(data,f, sort_keys=False)
PY
  sops -e --input-type yaml --output-type yaml "$tmp" > secrets/agents.enc.yaml
  rm -f "$tmp"
  echo "[secrets] repo‑encrypted secrets updated (non‑interactive)"
}

action_rotate(){
  ensure_sops
  key="${1:-}"; val="${2:-}"
  [ -n "$key" ] && [ -n "$val" ] || { echo "usage: scripts/agents rotate <KEY> <VALUE>"; exit 2; }
  tmp="$(mktemp)"; sops -d secrets/agents.enc.yaml > "$tmp" 2>/dev/null || printf '---\n' > "$tmp"
  python3 - "$tmp" "$key" "$val" <<'PY'
import sys, yaml
p, k, v = sys.argv[1:4]
with open(p) as f: data = yaml.safe_load(f) or {}
data[k]=v
with open(p,'w') as f: yaml.safe_dump(data,f, sort_keys=False)
PY
  sops -e --input-type yaml --output-type yaml "$tmp" > secrets/agents.enc.yaml
  rm -f "$tmp"
  echo "[secrets] rotated $key"
}

action_run(){
  agent="${1:-}"; tag="${2:-latest-convo}"; shift 2 || true
  prompt="$*"; [ -n "$prompt" ] || prompt="$(cat)"
  case "$agent" in
    claude)  printf "%s" "$prompt" | "$ROOT/scripts/claude-cli" | "$ROOT/scripts/log-jsonl" "claude" "$tag" ;;
    gemini)  printf "%s" "$prompt" | "$ROOT/scripts/gemini-cli" | "$ROOT/scripts/log-jsonl" "gemini" "$tag" ;;
    codex)   printf "%s" "$prompt" | "$ROOT/scripts/codex-cli"  | "$ROOT/scripts/log-jsonl" "codex"  "$tag" ;;
    *) echo "usage: scripts/agents run {claude|gemini|codex} <tag> \"prompt…\""; exit 2;;
  esac
}

case "$cmd" in
  repo-secrets) action_repo_secrets ;;
  rotate)       action_rotate "$@" ;;
  run)          action_run "$@" ;;
  *) cat <<USAGE
Usage: scripts/agents {repo-secrets|rotate|run}
  repo-secrets           Merge ANTHROPIC_API_KEY/GEMINI_API_KEY from env → encrypted secrets
  rotate <KEY> <VALUE>   Set/rotate a single key into encrypted secrets
  run <agent> <tag> "…"  Run native CLI and append JSONL in one go
USAGE
     ;;
esac