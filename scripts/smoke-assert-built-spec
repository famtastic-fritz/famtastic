#!/usr/bin/env node
'use strict';

/**
 * P0.4 — post-build spec invariant assertion.
 *
 * After a successful build (Shay confirm path or any other), the site's
 * spec.json must satisfy:
 *
 *   - state ∈ {built, deployed, client_approved}
 *   - design_brief exists
 *   - design_brief.approved === true   ← the regression P0.4 closes
 *   - interview_completed === true
 *   - pages array is non-empty
 *
 * Without design_brief.approved === true, the classifier's hasBrief gate
 * (server.js:11308) returns false on every subsequent chat message, breaking
 * content edits, deploys, and restyle. This is the single bug responsible
 * for Gates 1, 2, and 4 failing in the 2026-04-27 P0 exit run.
 *
 * Usage:
 *   scripts/smoke-assert-built-spec <tag>
 *
 * Exit codes:
 *   0 — all post-build invariants hold
 *   1 — at least one invariant violated
 *   2 — input/setup error
 */

const fs = require('fs');
const path = require('path');

const SITES_ROOT = path.join(__dirname, '..', 'sites');

const arg = process.argv[2];
if (!arg) {
  console.log('Usage: smoke-assert-built-spec <tag>');
  process.exit(2);
}
const tag = arg.startsWith('site-') ? arg : `site-${arg}`;
const specPath = path.join(SITES_ROOT, tag, 'spec.json');

if (!fs.existsSync(specPath)) {
  console.log(`[error] spec.json not found at ${specPath}`);
  process.exit(2);
}

let spec;
try {
  spec = JSON.parse(fs.readFileSync(specPath, 'utf8'));
} catch (e) {
  console.log(`[error] parse failure: ${e.message}`);
  process.exit(2);
}

const builtStates = ['built', 'deployed', 'client_approved'];
const failures = [];

if (!builtStates.includes(spec.state)) {
  failures.push(`state should be one of ${JSON.stringify(builtStates)}; got ${JSON.stringify(spec.state)}`);
}
if (!spec.design_brief || typeof spec.design_brief !== 'object') {
  failures.push('design_brief missing or not an object');
} else if (spec.design_brief.approved !== true) {
  failures.push(`design_brief.approved should be true; got ${JSON.stringify(spec.design_brief.approved)}`);
}
if (spec.interview_completed !== true) {
  failures.push(`interview_completed should be true; got ${JSON.stringify(spec.interview_completed)}`);
}
if (!Array.isArray(spec.pages) || spec.pages.length === 0) {
  failures.push(`pages should be a non-empty array; got ${JSON.stringify(spec.pages)}`);
}

console.log(`=== Post-Build Spec Assertion — ${tag} ===`);
console.log(`state: ${JSON.stringify(spec.state)}`);
console.log(`design_brief.approved: ${JSON.stringify(spec.design_brief && spec.design_brief.approved)}`);
console.log(`interview_completed: ${JSON.stringify(spec.interview_completed)}`);
console.log(`pages: ${JSON.stringify(spec.pages)}`);

if (failures.length > 0) {
  console.log('\n=== Failures ===');
  failures.forEach(f => console.log(`  FAIL: ${f}`));
  console.log('\n=== Exit: 1 ===');
  process.exit(1);
}

console.log('\n=== Exit: 0 (all invariants hold) ===');
process.exit(0);
