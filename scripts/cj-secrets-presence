#!/usr/bin/env bash
set -euo pipefail

# This script checks for the presence of secrets in the environment or OS vault.
# It reads the providers from agents/catalog.json.

# Path to the catalog file
CATALOG_FILE="agents/catalog.json"

# Check if jq is installed
if ! command -v jq &> /dev/null;
then
    echo "jq could not be found. Please install jq."
    exit 1
fi

# Read providers from catalog.json
providers=$(jq -r '.providers[]' "$CATALOG_FILE")

if [[ "${1:-}" == "--summary" ]]; then
    for provider in $providers;
    do
        # Check macOS Keychain
        if [[ "$(uname)" == "Darwin" ]]; then
            if security find-generic-password -s "agents:$provider" -a "$USER" &> /dev/null;
            then
                echo "$provider: PRESENT"
                continue
            fi
        fi

        # Check for env vars defined in catalog.json
        env_key=$(jq -r ".env_keys_any.\"$provider\" // \"\"" "$CATALOG_FILE")
        if [[ -n "$env_key" && -n "${!env_key:-}" ]]; then
            echo "$provider: PRESENT"
            continue
        fi

        echo "$provider: MISSING"
    done
else
    echo "Checking for secrets..."
    for provider in $providers;
    do
        # Check macOS Keychain
        if [[ "$(uname)" == "Darwin" ]]; then
            if security find-generic-password -s "agents:$provider" -a "$USER" &> /dev/null;
            then
                echo "- $provider: PRESENT in macOS Keychain"
                continue
            fi
        fi

        # Check for env vars defined in catalog.json
        env_key=$(jq -r ".env_keys_any.\"$provider\" // \"\"" "$CATALOG_FILE")
        if [[ -n "$env_key" && -n "${!env_key:-}" ]]; then
            echo "- $provider: PRESENT as environment variable ($env_key)"
            continue
        fi

        echo "- $provider: MISSING"
    done
fi
