  "_audit_provenance": "cowork-audit-001 \u2014 registered after the audit identified that MBSH lived in two locations (asset workshop at ~/famtastic/sites/site-mbsh-reunion/ + deploy repo at ~/famtastic-sites/mbsh-reunion/) but had no Studio spec.json. This file makes Studio aware of MBSH as a buildable spec without violating the repo-separation rule (deploy artifacts stay in the sibling repo).",
  "design_brief": {
    "goal": "Convert reunion classmates into RSVPs and create the FAMtastic public showcase build. Every alum who sees this site is a potential FAMtastic client. Quality bar: would the most prominent alum text their network to say 'this is fire.'",
    "audience": "MBSH Class of '96 alumni, primarily ages ~46-50, encountering the site first on mobile (most likely at 11pm in bed). Secondary audience: visiting alums from other classes (the 100th anniversary frame), prospective FAMtastic clients evaluating the showcase quality.",
    "tone": [
      "cinematic",
      "elegant",
      "black-tie",
      "reverent-when-needed",
      "warm-but-restrained"
    ],
    "visual_direction": {
      "layout": "Cinematic full-bleed hero with layered composition (background loop + brand mark top-left + center typography stack + Hi-Tide Harry bottom-right + scroll-tease bottom-center). Slow deliberate animations. Generous whitespace. High-contrast imagery treated like film stills. Mobile-first.",
      "typography": "Six-font system: Playfair Display 900 (display), Cormorant Garamond italic (body/captions), Allura cursive (overlay statements), Great Vibes (taglines), Inter 400/600 (UI), JetBrains Mono (data). Five fonts per page maximum.",
      "color_usage": "Red and white lead, silver and cream accent. Silver is metallic gradient NOT flat gray. Off-black #0A0A0A NOT pure black. Cream #F8F4EC for sections needing air.",
      "motion": "Hero background video loops silently. Story moments fade in on scroll via IntersectionObserver. 30+100 brand mark on Forever moment has subtle pulse animation. No autoplay audio.",
      "density": "spacious"
    },
    "content_priorities": [
      "Make the first 5 seconds produce awe and pride",
      "Reduce RSVP friction",
      "Sponsor track funds the event (donation tiers + manual approval gate)",
      "Honor classmates lost (In Memory section, reverent restraint)",
      "Surprise emotional payoff (Time Capsule sends to classmates' future selves on July 12)",
      "Living soundtrack (Spotify playlist, embedded)",
      "First branded AI chatbot built through Studio (Hi-Tide Harry, Phase 1 = FAQ + fallback)"
    ],
    "must_have_sections": [
      "home",
      "rsvp",
      "tickets",
      "through-years",
      "memorial",
      "capsule",
      "playlist"
    ],
    "avoid": [
      "Generic stock imagery (use generated atmospherics + archival sources)",
      "Single-page architecture (committee explicitly rejected last time \u2014 captured 2026-04-29)",
      "Provider names in user-facing UI strings",
      "Name-dropping of celebrity alumni",
      "Emoji except \ud83c\udf0a (Hi-Tide wave)",
      "Autoplay audio",
      "More than 5 fonts on any page",
      "Pure black #000 (use #0A0A0A off-black)",
      "Flat silver (use metallic gradient)",
      "SVG uploads in any user-facing form (security: SVG can carry executable JS)",
      "Auth tokens via URL parameters",
      "Force pushes to git",
      "AI references in commit messages"
    ],
    "approved": true,
    "tier": "famtastic",
    "audience_gating": "flagship",
