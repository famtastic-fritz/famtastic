{
  "name": "@famtastic/remotion",
  "version": "0.1.0",
  "description": "FAMtastic shared animation & rendering engine — Remotion compositions used by site-studio, media-studio, and component-studio.",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "render:luminous": "remotion render FAMtasticLogo-Luminous out/famtastic-logo-luminous.mp4",
    "render:dark": "remotion render FAMtasticLogo-Dark out/famtastic-logo-dark.mp4",
    "render:square": "remotion render FAMtasticLogo-Square out/famtastic-logo-square.mp4",
    "render:still": "remotion still FAMtasticLogo-Luminous out/famtastic-logo.png --frame=60"
  },
  "repository": {},
  "license": "UNLICENSED",
