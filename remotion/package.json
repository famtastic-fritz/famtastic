    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.463",
    "@remotion/media-utils": "^4.0.463",
    "@remotion/player": "^4.0.463",
    "@remotion/preload": "^4.0.463",
    "@remotion/shapes": "^4.0.463",
    "@remotion/transitions": "^4.0.463",
    "@remotion/zod-types": "^4.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "^4.0.0",
    "zod": "4.3.6"
