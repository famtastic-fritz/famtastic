node_modules/
.DS_Store

# Site working directories — local only, not committed to hub repo
# Each site gets its own repo at ~/famtastic-sites/<tag>/
sites/

# Local Netlify folder
.netlify

# Claude Code worktrees — ephemeral, never tracked
.claude/worktrees/

# Claude Code local settings — captures approved Bash commands verbatim,
# which can include inline env-var API keys. Never tracked.
.claude/settings.local.json

# Local tools (adb-mcp bridge etc) — machine-specific, not tracked
tools/

# Session 12 Phase 1 safety net: PENDING-REVIEW.md is supposed to live at
# ~/PENDING-REVIEW.md (outside the repo). This entry catches the case where
# someone accidentally drops it inside the repo — never commit intel output.
PENDING-REVIEW.md

# OpenWolf — ephemeral/local files (anatomy.md, cerebrum.md, buglog.json are tracked)
.wolf/token-ledger.json
.wolf/memory.md
.wolf/hooks/
.wolf/config.json
.wolf/*.log
.wolf/cron-manifest.json
.wolf/cron-state.json
.wolf/designqc-report.json
.wolf/identity.md
.wolf/suggestions.json
